#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLAUSE_DIR="$HOME/.clause"
CONF_FILE="$CLAUSE_DIR/clause.conf"

# ── Bootstrap ~/.clause layout ──────────────────────────────────────────────

mkdir -p "$CLAUSE_DIR/profiles/default/.claude"
touch "$CLAUSE_DIR/profiles/default/.claude.json"
touch "$CLAUSE_DIR/profiles/default/.gitconfig"
touch "$CONF_FILE"

usage() {
  echo "usage: clause [-h] [profile] [options]"
  echo ""
  echo "arguments:"
  echo "  profile             Profile to use (default: 'default')"
  echo ""
  echo "session options:"
  echo "  -w, --workspace     Workspace directory (default: \$PWD)"
  echo "  -S, --new-session   Start a new session (skip auto-resume)"
  echo "  -b, --bash          Launch bash instead of claude"
  echo ""
  echo "prompt options:"
  echo "  -y, --yes           Auto-answer yes to all prompts"
  echo "  -n, --no            Auto-answer no to all prompts"
  echo ""
  echo "mapping management (then exit):"
  echo "  -a, --add           Add workspace→profile mapping"
  echo "  -m, --mapping       Show workspace→profile mapping for current workspace"
  echo "  -R, --remove        Remove workspace→profile mapping"
  echo "  -l, --list          List all workspace→profile mappings"
  echo ""
  echo "profile management (then exit):"
  echo "  --profile-create        Create a new profile scaffold and add mapping"
  echo "  --profile-delete        Delete a profile and remove its mappings"
  echo "  --profile-create-image  Copy default Containerfile into profile directory"
  echo "  --profile-delete-image  Delete profile Containerfile and podman image"
  echo ""
  echo "other:"
  echo "  -B, --build         Build the container image"
  echo "  -h, --help          Print this help"
}

# ── Argument parsing ────────────────────────────────────────────────────────

OPT_CREATE_PROFILE=false
OPT_DELETE_PROFILE=false
OPT_CREATE_PROFILE_IMAGE=false
OPT_DELETE_PROFILE_IMAGE=false
OPT_BUILD=false
OPT_Y=false
OPT_N=false
OPT_B=false
OPT_R=false
OPT_NEW_SESSION=false
OPT_A=false
OPT_M=false
OPT_PROFILE=""
OPT_W=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile-create) OPT_CREATE_PROFILE=true; shift ;;
    --profile-delete) OPT_DELETE_PROFILE=true; shift ;;
    --profile-create-image) OPT_CREATE_PROFILE_IMAGE=true; shift ;;
    --profile-delete-image) OPT_DELETE_PROFILE_IMAGE=true; shift ;;
    -B|--build) OPT_BUILD=true; shift ;;
    -h|--help) usage; exit 0 ;;
    -l|--list)
      if [[ ! -f "$CONF_FILE" ]] || [[ ! -s "$CONF_FILE" ]]; then
        echo "(no mappings)"
      else
        cat "$CONF_FILE"
      fi
      exit 0
      ;;
    -y|--yes) OPT_Y=true; shift ;;
    -n|--no) OPT_N=true; shift ;;
    -b|--bash) OPT_B=true; shift ;;
    -S|--new-session) OPT_NEW_SESSION=true; shift ;;
    -R|--remove) OPT_R=true; shift ;;
    -a|--add) OPT_A=true; shift ;;
    -m|--mapping) OPT_M=true; shift ;;
    -w|--workspace)
      [[ $# -lt 2 ]] && { echo "Error: $1 requires a path" >&2; exit 1; }
      OPT_W="$2"
      shift 2
      ;;
    -*)
      echo "Error: unknown option '$1'" >&2; usage >&2; exit 1
      ;;
    *)
      if [[ -n "$OPT_PROFILE" ]]; then
        echo "Error: unexpected argument '$1'" >&2; usage >&2; exit 1
      fi
      OPT_PROFILE="${1,,}"
      shift
      ;;
  esac
done

# ── Mutual exclusivity checks ───────────────────────────────────────────────

if [[ "$OPT_Y" == true && "$OPT_N" == true ]]; then
  echo "Error: -y and -n are mutually exclusive" >&2; exit 1
fi


PROFILE_MGMT_COUNT=0
[[ "$OPT_CREATE_PROFILE" == true ]] && (( ++PROFILE_MGMT_COUNT ))
[[ "$OPT_DELETE_PROFILE" == true ]] && (( ++PROFILE_MGMT_COUNT ))
[[ "$OPT_CREATE_PROFILE_IMAGE" == true ]] && (( ++PROFILE_MGMT_COUNT ))
[[ "$OPT_DELETE_PROFILE_IMAGE" == true ]] && (( ++PROFILE_MGMT_COUNT ))
if [[ "$PROFILE_MGMT_COUNT" -gt 1 ]]; then
  echo "Error: --profile-create, --profile-delete, --profile-create-image, and --profile-delete-image are mutually exclusive" >&2; exit 1
fi

# ── Resolve workspace ───────────────────────────────────────────────────────

if [[ -n "$OPT_W" ]]; then
  if [[ ! -d "$OPT_W" ]]; then
    echo "Error: workspace '$OPT_W' is not a directory" >&2; exit 1
  fi
  WORKSPACE="$(realpath "$OPT_W")"
else
  WORKSPACE="$(realpath "$PWD")"
fi

# ── Config helpers ──────────────────────────────────────────────────────────

config_get() {
  local workspace="$1"
  [[ ! -f "$CONF_FILE" ]] && echo "" && return
  awk -F= -v ws="$workspace" '$1 == ws { print $2; exit }' "$CONF_FILE" || echo ""
}

config_set() {
  local workspace="$1" profile="$2"
  config_del "$workspace"
  echo "${workspace}=${profile}" >> "$CONF_FILE"
}

config_del() {
  local workspace="$1"
  [[ ! -f "$CONF_FILE" ]] && return
  awk -F= -v ws="$workspace" '$1 != ws' "$CONF_FILE" > "${CONF_FILE}.tmp"
  mv "${CONF_FILE}.tmp" "$CONF_FILE"
}

config_del_by_profile() {
  local profile="$1"
  [[ ! -f "$CONF_FILE" ]] && echo "0" && return
  local count
  count=$(awk -F= -v p="$profile" '$2 == p { c++ } END { print c+0 }' "$CONF_FILE")
  awk -F= -v p="$profile" '$2 != p' "$CONF_FILE" > "${CONF_FILE}.tmp"
  mv "${CONF_FILE}.tmp" "$CONF_FILE"
  echo "$count"
}

# ── Session helpers ─────────────────────────────────────────────────────────

session_get() {
  local f="$WORKSPACE/.last-session-id"
  [[ -f "$f" ]] && tr -d '[:space:]' < "$f" || echo ""
}

session_del() {
  rm -f "$WORKSPACE/.last-session-id"
}

# ── Prompt helper ───────────────────────────────────────────────────────────

# Sets global PROMPT_REPLY to y, n, or q
prompt_ynq() {
  local message="$1"
  if [[ "$OPT_Y" == true ]]; then
    echo "${message} [y/n/q] y"
    PROMPT_REPLY="y"
    return
  fi
  if [[ "$OPT_N" == true ]]; then
    echo "${message} [y/n/q] n"
    PROMPT_REPLY="n"
    return
  fi
  read -r -n 1 -p "${message} [y/n/q] " PROMPT_REPLY
  echo
}

# ── Profile resolution helper (silent, for management commands) ─────────────

profile_for_management() {
  local saved
  saved="$(config_get "$WORKSPACE")"
  echo "${OPT_PROFILE:-${saved:-default}}"
}

# ── Management: --build ──────────────────────────────────────────────────────

if [[ "$OPT_BUILD" == true ]]; then
  BUILD_PROFILE="$(profile_for_management)"
  BUILD_PROFILE_DIR="$CLAUSE_DIR/profiles/$BUILD_PROFILE"
  if [[ -f "$BUILD_PROFILE_DIR/Containerfile" ]]; then
    podman build -t "clause-$BUILD_PROFILE" "$BUILD_PROFILE_DIR"
  else
    podman build -t clause "$SCRIPT_DIR"
  fi
  exit 0
fi

# ── Management: --profile-create ───────────────────────────────────────────

if [[ "$OPT_CREATE_PROFILE" == true ]]; then
  PROFILE_NAME="${OPT_PROFILE:-default}"
  PROFILE_DIR="$CLAUSE_DIR/profiles/$PROFILE_NAME"
  if [[ -d "$PROFILE_DIR" ]]; then
    echo "Error: profile '$PROFILE_NAME' already exists" >&2; exit 1
  fi
  read -r -p "Create profile '$PROFILE_NAME'? Type 'yes' to confirm: " CONFIRM
  if [[ "$CONFIRM" != "yes" ]]; then
    echo "Aborted."; exit 0
  fi
  mkdir -p "$PROFILE_DIR/.claude"
  touch "$PROFILE_DIR/.gitconfig"
  echo "Created profile '$PROFILE_NAME'"
  config_set "$WORKSPACE" "$PROFILE_NAME"
  echo "Mapped $WORKSPACE → $PROFILE_NAME"
  exit 0
fi

# ── Management: --profile-delete ───────────────────────────────────────────

if [[ "$OPT_DELETE_PROFILE" == true ]]; then
  PROFILE_NAME="${OPT_PROFILE:-default}"
  if [[ "$PROFILE_NAME" == "default" ]]; then
    echo "Error: cannot delete the default profile" >&2; exit 1
  fi
  PROFILE_DIR="$CLAUSE_DIR/profiles/$PROFILE_NAME"
  if [[ ! -d "$PROFILE_DIR" ]]; then
    echo "Error: profile '$PROFILE_NAME' does not exist" >&2; exit 1
  fi
  read -r -p "Delete profile '$PROFILE_NAME' and all its data? Type 'yes' to confirm: " CONFIRM
  if [[ "$CONFIRM" != "yes" ]]; then
    echo "Aborted."; exit 0
  fi
  rm -rf "$PROFILE_DIR"
  COUNT=$(config_del_by_profile "$PROFILE_NAME")
  [[ "$COUNT" -gt 0 ]] && echo "Removed ${COUNT} mapping(s) for profile '$PROFILE_NAME'"
  echo "Deleted profile '$PROFILE_NAME'"
  exit 0
fi

# ── Mapping management: -a / --add ─────────────────────────────────────────

if [[ "$OPT_A" == true ]]; then
  PROFILE_NAME="${OPT_PROFILE:-default}"
  if [[ ! -d "$CLAUSE_DIR/profiles/$PROFILE_NAME" ]]; then
    echo "Error: profile '$PROFILE_NAME' does not exist. Create it with: clause $PROFILE_NAME --profile-create" >&2; exit 1
  fi
  EXISTING="$(config_get "$WORKSPACE")"
  if [[ -n "$EXISTING" ]]; then
    echo "Warning: $WORKSPACE is already mapped to '$EXISTING'"
    prompt_ynq "Overwrite with '$PROFILE_NAME'?"
    case "$PROMPT_REPLY" in
      y|Y) ;;
      *) echo "Aborted."; exit 0 ;;
    esac
  fi
  config_set "$WORKSPACE" "$PROFILE_NAME"
  echo "Mapped $WORKSPACE → $PROFILE_NAME"
  exit 0
fi

# ── Mapping management: -m / --mapping ─────────────────────────────────────

if [[ "$OPT_M" == true ]]; then
  RESULT="$(config_get "$WORKSPACE")"
  if [[ -n "$RESULT" ]]; then
    echo "$WORKSPACE → $RESULT"
  else
    echo "(no mapping)"
  fi
  exit 0
fi

# ── Mapping management: -R / --remove ──────────────────────────────────────

if [[ "$OPT_R" == true ]]; then
  SAVED="$(config_get "$WORKSPACE")"
  if [[ -z "$SAVED" ]]; then
    echo "Error: no mapping found for $WORKSPACE" >&2; exit 1
  fi
  prompt_ynq "Remove mapping $WORKSPACE → $SAVED?"
  case "$PROMPT_REPLY" in
    y|Y)
      config_del "$WORKSPACE"
      echo "Removed mapping: $WORKSPACE → $SAVED"
      ;;
    n|N)
      echo "Aborted."
      ;;
    *)
      echo "Aborted."
      ;;
  esac
  exit 0
fi

# ── Resolve profile ─────────────────────────────────────────────────────────

REQUESTED="${OPT_PROFILE:-default}"
SAVED="$(config_get "$WORKSPACE")"
PROMPT_REPLY=""

if [[ -n "$SAVED" && -z "$OPT_PROFILE" ]]; then
  PROFILE="$SAVED"
elif [[ -z "$SAVED" || "$SAVED" != "$REQUESTED" ]]; then
  if [[ -z "$SAVED" ]]; then
    MSG="No mapping found. Save $WORKSPACE → $REQUESTED?"
  else
    MSG="Workspace mapped to '$SAVED'. Override with '$REQUESTED'?"
  fi
  prompt_ynq "$MSG"
  case "$PROMPT_REPLY" in
    y|Y)
      config_set "$WORKSPACE" "$REQUESTED"
      PROFILE="$REQUESTED"
      ;;
    n|N)
      PROFILE="${SAVED:-$REQUESTED}"
      ;;
    *)
      echo "Aborted."; exit 0
      ;;
  esac
else
  PROFILE="$SAVED"
fi

# ── Verify profile exists ───────────────────────────────────────────────────

PROFILE_DIR="$CLAUSE_DIR/profiles/$PROFILE"
if [[ ! -d "$PROFILE_DIR" ]]; then
  echo "Error: profile '$PROFILE' does not exist. Create it with: clause $PROFILE --profile-create" >&2
  exit 1
fi

# ── Init profile runtime data ───────────────────────────────────────────────

mkdir -p "$PROFILE_DIR/.claude"
touch "$PROFILE_DIR/.claude.json"
touch "$PROFILE_DIR/.gitconfig"

if ! grep -q 'last-session-id' "$PROFILE_DIR/.claude/settings.json" 2>/dev/null; then
  cat > "$PROFILE_DIR/.claude/settings.json" <<'EOF'
{
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.session_id' > /workspace/.last-session-id"
          }
        ]
      }
    ]
  }
}
EOF
fi

# ── Ensure image exists ─────────────────────────────────────────────────────

if ! podman image exists clause; then
  echo "Error: 'clause' image not found. Build it with: clause --build" >&2
  exit 1
fi

# ── Resolve container command ───────────────────────────────────────────────

if [[ "$OPT_NEW_SESSION" == false ]] && ! grep -q 'last-session-id' "$PROFILE_DIR/.claude/settings.json" 2>/dev/null; then
  prompt_ynq "Warning: session restore is enabled but the session hook is not configured for profile '$PROFILE'. Continue?"
  case "$PROMPT_REPLY" in
    y|Y) OPT_NEW_SESSION=true ;;
    *) echo "Aborted."; exit 0 ;;
  esac
fi

if [[ "$OPT_B" == true ]]; then
  CONTAINER_CMD=(bash)
elif [[ "$OPT_NEW_SESSION" == false ]]; then
  SESSION_ID="$(session_get)"
  if [[ -n "$SESSION_ID" ]]; then
    if [[ ! -d "$PROFILE_DIR/.claude/session-env/$SESSION_ID" ]]; then
      session_del
      prompt_ynq "Warning: saved session '$SESSION_ID' not found in profile. Start a new session?"
      case "$PROMPT_REPLY" in
        y|Y) CONTAINER_CMD=(claude) ;;
        *) echo "Aborted."; exit 0 ;;
      esac
    else
      session_del
      CONTAINER_CMD=(claude --resume "$SESSION_ID")
    fi
  else
    CONTAINER_CMD=(claude)
  fi
else
  CONTAINER_CMD=(claude)
fi

# ── Launch container ────────────────────────────────────────────────────────

CONTAINER_NAME="clause-$$"

cleanup() {
  podman stop "$CONTAINER_NAME" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

podman run --rm -it --name "$CONTAINER_NAME" \
  -v "$PROFILE_DIR/.claude:/root/.claude" \
  -v "$PROFILE_DIR/.claude.json:/root/.claude.json" \
  -v "$PROFILE_DIR/.gitconfig:/root/.gitconfig" \
  -v "$WORKSPACE:/workspace" \
  -w /workspace \
  clause \
  "${CONTAINER_CMD[@]}"
