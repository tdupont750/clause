#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLAUSE_DIR="$HOME/.clause"
CONF_FILE="$CLAUSE_DIR/clause.conf"
RUNTIME_FILE="$CLAUSE_DIR/runtime"

usage() {
  cat <<'EOF'
usage: clause [-h] [profile] [options]

arguments:
  profile                 Profile to use (default: 'default')

session options:
  -a, --args <value>      One-shot claude args (overrides clause-args files)
  -t, --terminal          Launch bash instead of claude
  -w, --workspace <path>  Workspace directory (default: $PWD)

prompt options:
  -y, --yes               Auto-answer yes to prompts (destructive
                          confirmations still require typing 'yes')
  -n, --no                Auto-answer no to all prompts

mapping (then exit):
  -m, --map               Add workspace→profile mapping
  -u, --unmap             Remove workspace→profile mapping
  -l, --list              Show current mapping and list all profiles
  -L, --list-all          List all workspace→profile mappings

profile management (then exit):
  -C, --create-profile        Create a new profile (Containerfile + clause-args seeded)
  -D, --delete-profile        Delete a profile and remove its mappings
  -R, --reset-containerfile   Overwrite profile Containerfile with default
  -S, --suggest-updates       Suggest Containerfile updates from sudo log

arguments (then exit):
  -A, --args-view                 Print effective claude args + source
      --args-set <value>          Write workspace .clause-args (this directory)
      --args-set-profile <value>  Write profile clause-args
                                  Default: --effort max --dangerously-skip-permissions

nested podman (then exit):
  -P, --podman-enable     Enable nested podman for profile (marker + Containerfile block)
      --podman-disable    Disable nested podman for profile
      --podman-reset      Remove the profile's nested-podman storage volume

alias management (then exit):
  --alias-create          Add clause alias to .bashrc and/or .zshrc
  --alias-delete          Remove clause alias from .bashrc and/or .zshrc

runtime management (then exit):
  --runtime-set <value>   Set container runtime override (podman or docker)
  --runtime-remove        Remove container runtime override

other:
  -b, --build             Build the container image
  -h, --help              Print this help
EOF
}

# ── Argument parsing ────────────────────────────────────────────────────────

OPT_CREATE_PROFILE=false
OPT_DELETE_PROFILE=false
OPT_RESET_CONTAINERFILE=false
OPT_ARGS_SET_PROFILE=""
OPT_ARGS_SET_PROFILE_GIVEN=false
OPT_ARGS_SET=""
OPT_ARGS_SET_GIVEN=false
OPT_ARGS_VIEW=false
OPT_ONETIME_ARGS=""
OPT_ONETIME_ARGS_GIVEN=false
OPT_SUGGEST_UPDATES=false
OPT_PODMAN_ENABLE=false
OPT_PODMAN_DISABLE=false
OPT_PODMAN_RESET=false
OPT_LIST=false
OPT_LIST_ALL=false
OPT_CREATE_ALIAS=false
OPT_DELETE_ALIAS=false
OPT_SET_RUNTIME=""
OPT_REMOVE_RUNTIME=false
OPT_BUILD=false
OPT_Y=false
OPT_N=false
OPT_T=false
OPT_UNMAP=false
OPT_MAP=false
OPT_PROFILE=""
OPT_W=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    # session options
    -a|--args)
      [[ $# -lt 2 ]] && { echo "Error: $1 requires a string value" >&2; exit 1; }
      OPT_ONETIME_ARGS="$2"
      OPT_ONETIME_ARGS_GIVEN=true
      shift 2
      ;;
    -t|--terminal) OPT_T=true; shift ;;
    -w|--workspace)
      [[ $# -lt 2 ]] && { echo "Error: $1 requires a path" >&2; exit 1; }
      OPT_W="$2"
      shift 2
      ;;

    # prompt options
    -y|--yes) OPT_Y=true; shift ;;
    -n|--no) OPT_N=true; shift ;;

    # mapping (then exit)
    -m|--map) OPT_MAP=true; shift ;;
    -u|--unmap) OPT_UNMAP=true; shift ;;
    -l|--list) OPT_LIST=true; shift ;;
    -L|--list-all) OPT_LIST_ALL=true; shift ;;

    # profile management (then exit)
    -C|--create-profile) OPT_CREATE_PROFILE=true; shift ;;
    -D|--delete-profile) OPT_DELETE_PROFILE=true; shift ;;
    -R|--reset-containerfile) OPT_RESET_CONTAINERFILE=true; shift ;;
    -S|--suggest-updates) OPT_SUGGEST_UPDATES=true; shift ;;

    # arguments (then exit)
    -A|--args-view) OPT_ARGS_VIEW=true; shift ;;
    --args-set)
      [[ $# -lt 2 ]] && { echo "Error: $1 requires a string value" >&2; exit 1; }
      OPT_ARGS_SET="$2"
      OPT_ARGS_SET_GIVEN=true
      shift 2
      ;;
    --args-set-profile)
      [[ $# -lt 2 ]] && { echo "Error: $1 requires a string value" >&2; exit 1; }
      OPT_ARGS_SET_PROFILE="$2"
      OPT_ARGS_SET_PROFILE_GIVEN=true
      shift 2
      ;;

    # nested podman (then exit)
    -P|--podman-enable) OPT_PODMAN_ENABLE=true; shift ;;
    --podman-disable) OPT_PODMAN_DISABLE=true; shift ;;
    --podman-reset) OPT_PODMAN_RESET=true; shift ;;

    # alias management (then exit)
    --alias-create) OPT_CREATE_ALIAS=true; shift ;;
    --alias-delete) OPT_DELETE_ALIAS=true; shift ;;

    # runtime management (then exit)
    --runtime-set)
      [[ $# -lt 2 ]] && { echo "Error: --runtime-set requires a value (podman or docker)" >&2; exit 1; }
      OPT_SET_RUNTIME="$2"
      shift 2
      ;;
    --runtime-remove) OPT_REMOVE_RUNTIME=true; shift ;;

    # other
    -b|--build) OPT_BUILD=true; shift ;;
    -h|--help) usage; exit 0 ;;

    # fallthrough
    -*)
      echo "Error: unknown option '$1'" >&2; usage >&2; exit 1
      ;;
    *)
      if [[ -n "$OPT_PROFILE" ]]; then
        echo "Error: unexpected argument '$1'" >&2; usage >&2; exit 1
      fi
      OPT_PROFILE="${1,,}"
      shift
      ;;
  esac
done

# ── Mutual exclusivity checks ───────────────────────────────────────────────

if [[ "$OPT_Y" == true && "$OPT_N" == true ]]; then
  echo "Error: -y and -n are mutually exclusive" >&2; exit 1
fi

MGMT_COUNT=0
[[ "$OPT_CREATE_PROFILE" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_DELETE_PROFILE" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_RESET_CONTAINERFILE" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_ARGS_SET_PROFILE_GIVEN" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_ARGS_SET_GIVEN" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_ARGS_VIEW" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_SUGGEST_UPDATES" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_PODMAN_ENABLE" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_PODMAN_DISABLE" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_PODMAN_RESET" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_LIST" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_LIST_ALL" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_MAP" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_UNMAP" == true ]] && (( ++MGMT_COUNT ))
if [[ "$MGMT_COUNT" -gt 1 ]]; then
  echo "Error: mapping/profile management options are mutually exclusive" >&2; exit 1
fi

if [[ "$OPT_CREATE_ALIAS" == true && "$OPT_DELETE_ALIAS" == true ]]; then
  echo "Error: --alias-create and --alias-delete are mutually exclusive" >&2; exit 1
fi

if [[ -n "$OPT_SET_RUNTIME" && "$OPT_REMOVE_RUNTIME" == true ]]; then
  echo "Error: --runtime-set and --runtime-remove are mutually exclusive" >&2; exit 1
fi

# ── Resolve workspace ───────────────────────────────────────────────────────

if [[ -n "$OPT_W" ]]; then
  if [[ ! -d "$OPT_W" ]]; then
    echo "Error: workspace '$OPT_W' is not a directory" >&2; exit 1
  fi
  WORKSPACE="$(realpath "$OPT_W")"
else
  WORKSPACE="$(realpath "$PWD")"
fi

# ── Determine bootstrap / runtime needs ─────────────────────────────────────

# Pure read-only commands never touch ~/.clause.
SKIP_BOOTSTRAP=false
[[ "$OPT_LIST" == true || "$OPT_LIST_ALL" == true || "$OPT_ARGS_VIEW" == true ]] && SKIP_BOOTSTRAP=true

# Only commands that shell out to $CONTAINER_CLI need a runtime: --build, --delete-profile,
# --podman-reset, and the default launch path. Everything else (including --runtime-set, which
# manages the very setting that drives detection) should not error on a runtime-less system.
NEEDS_RUNTIME=true
[[ "$SKIP_BOOTSTRAP" == true ]] && NEEDS_RUNTIME=false
[[ "$OPT_CREATE_PROFILE" == true ]] && NEEDS_RUNTIME=false
[[ "$OPT_RESET_CONTAINERFILE" == true ]] && NEEDS_RUNTIME=false
[[ "$OPT_ARGS_SET_GIVEN" == true ]] && NEEDS_RUNTIME=false
[[ "$OPT_ARGS_SET_PROFILE_GIVEN" == true ]] && NEEDS_RUNTIME=false
[[ "$OPT_SUGGEST_UPDATES" == true ]] && NEEDS_RUNTIME=false
[[ "$OPT_PODMAN_ENABLE" == true ]] && NEEDS_RUNTIME=false
[[ "$OPT_PODMAN_DISABLE" == true ]] && NEEDS_RUNTIME=false
[[ "$OPT_CREATE_ALIAS" == true ]] && NEEDS_RUNTIME=false
[[ "$OPT_DELETE_ALIAS" == true ]] && NEEDS_RUNTIME=false
[[ -n "$OPT_SET_RUNTIME" ]] && NEEDS_RUNTIME=false
[[ "$OPT_REMOVE_RUNTIME" == true ]] && NEEDS_RUNTIME=false
[[ "$OPT_MAP" == true ]] && NEEDS_RUNTIME=false
[[ "$OPT_UNMAP" == true ]] && NEEDS_RUNTIME=false

# ── Profile runtime scaffold helper ─────────────────────────────────────────

# Create a profile's empty runtime files (idempotent, never overwrites).
# Defined up here because the bootstrap block below runs before the other
# helper sections.
init_profile_runtime() {
  local profile_dir="$1"
  mkdir -p "$profile_dir/.claude"
  [[ ! -f "$profile_dir/.claude.json" ]] && echo '{}' > "$profile_dir/.claude.json"
  touch "$profile_dir/.gitconfig" "$profile_dir/.claude/clause-sudo.log"
}

# ── Bootstrap ~/.clause layout (skipped for pure read-only commands) ───────

if [[ "$SKIP_BOOTSTRAP" != true ]]; then
  init_profile_runtime "$CLAUSE_DIR/profiles/default"
  touch "$CONF_FILE"
fi

# ── Detect container runtime (skipped for non-container commands) ──────────

if [[ "$NEEDS_RUNTIME" == true ]]; then
  if [[ -f "$RUNTIME_FILE" ]]; then
    CONTAINER_CLI="$(tr -d '[:space:]' < "$RUNTIME_FILE")"
    if [[ -z "$CONTAINER_CLI" ]]; then
      echo "Error: $RUNTIME_FILE is empty; remove it or run: clause --runtime-set podman" >&2; exit 1
    fi
    if [[ "$CONTAINER_CLI" != "podman" && "$CONTAINER_CLI" != "docker" ]]; then
      echo "Error: invalid runtime '$CONTAINER_CLI' in $RUNTIME_FILE. Must be 'podman' or 'docker'" >&2; exit 1
    fi
    if ! command -v "$CONTAINER_CLI" &>/dev/null; then
      echo "Error: runtime '$CONTAINER_CLI' set in $RUNTIME_FILE but not found on PATH" >&2; exit 1
    fi
  elif command -v podman &>/dev/null; then
    CONTAINER_CLI="podman"
  elif command -v docker &>/dev/null; then
    CONTAINER_CLI="docker"
  else
    echo "Error: neither podman nor docker found on PATH" >&2; exit 1
  fi
fi

# ── Config helpers ──────────────────────────────────────────────────────────

config_get() {
  local workspace="$1"
  [[ ! -f "$CONF_FILE" ]] && echo "" && return
  awk -F= -v ws="$workspace" '$1 == ws { print $2; exit }' "$CONF_FILE" || echo ""
}

config_set() {
  local workspace="$1" profile="$2"
  config_del "$workspace"
  echo "${workspace}=${profile}" >> "$CONF_FILE"
}

config_del() {
  local workspace="$1"
  [[ ! -f "$CONF_FILE" ]] && return
  awk -F= -v ws="$workspace" '$1 != ws' "$CONF_FILE" > "${CONF_FILE}.tmp"
  mv "${CONF_FILE}.tmp" "$CONF_FILE"
}

config_del_by_profile() {
  local profile="$1"
  [[ ! -f "$CONF_FILE" ]] && echo "0" && return
  local count
  count=$(awk -F= -v p="$profile" '$2 == p { c++ } END { print c+0 }' "$CONF_FILE")
  awk -F= -v p="$profile" '$2 != p' "$CONF_FILE" > "${CONF_FILE}.tmp"
  mv "${CONF_FILE}.tmp" "$CONF_FILE"
  echo "$count"
}

# ── Container helpers ───────────────────────────────────────────────────────

image_exists() {
  "$CONTAINER_CLI" image inspect "$1" &>/dev/null
}

volume_exists() {
  "$CONTAINER_CLI" volume inspect "$1" &>/dev/null
}

# ── Prompt helpers ──────────────────────────────────────────────────────────

# Sets global PROMPT_REPLY to y, n, or q
prompt_ynq() {
  local message="$1"
  if [[ "$OPT_Y" == true ]]; then
    echo "${message} [y/n/q] y"
    PROMPT_REPLY="y"
    return
  fi
  if [[ "$OPT_N" == true ]]; then
    echo "${message} [y/n/q] n"
    PROMPT_REPLY="n"
    return
  fi
  read -r -n 1 -p "${message} [y/n/q] " PROMPT_REPLY
  echo
}

# prompt_ynq wrapper: true only on an explicit yes
prompt_yes() {
  prompt_ynq "$1"
  [[ "$PROMPT_REPLY" =~ ^[yY]$ ]]
}

# Prompts for literal "yes"; returns 1 (false) if not confirmed.
# -n auto-declines; -y deliberately does not auto-confirm destructive actions.
confirm_yes() {
  local message="$1"
  local reply
  [[ "$OPT_N" == true ]] && return 1
  read -r -p "${message} Type 'yes' to confirm: " reply
  [[ "$reply" == "yes" ]]
}

# ── Profile resolution helper (silent, for management commands) ─────────────

profile_for_management() {
  local saved
  saved="$(config_get "$WORKSPACE")"
  echo "${OPT_PROFILE:-${saved:-default}}"
}

# Resolve PROFILE_NAME ($1 if given, else positional > mapping > default) and
# PROFILE_DIR; error out if the profile directory does not exist.
require_profile() {
  PROFILE_NAME="${1:-$(profile_for_management)}"
  PROFILE_DIR="$CLAUSE_DIR/profiles/$PROFILE_NAME"
  if [[ ! -d "$PROFILE_DIR" ]]; then
    echo "Error: profile '$PROFILE_NAME' does not exist. Create it with: clause $PROFILE_NAME --create-profile" >&2
    exit 1
  fi
}

# ── Claude args resolution helper ───────────────────────────────────────────

# Resolve the args appended to claude: -a/--args one-shot > workspace
# .clause-args (present file wins, even empty) > profile clause-args (same).
# Sets ARGS_LINE (first line of the winning source) and ARGS_SOURCE; an empty
# ARGS_SOURCE means no source was found. Uses globals WORKSPACE, PROFILE_DIR.
resolve_args() {
  ARGS_LINE=""
  ARGS_SOURCE=""
  if [[ "$OPT_ONETIME_ARGS_GIVEN" == true ]]; then
    ARGS_LINE="$OPT_ONETIME_ARGS"
    ARGS_SOURCE="-a/--args"
  elif [[ -f "$WORKSPACE/.clause-args" ]]; then
    read -r ARGS_LINE < "$WORKSPACE/.clause-args" || true
    ARGS_SOURCE="$WORKSPACE/.clause-args"
  elif [[ -f "$PROFILE_DIR/clause-args" ]]; then
    read -r ARGS_LINE < "$PROFILE_DIR/clause-args" || true
    ARGS_SOURCE="$PROFILE_DIR/clause-args"
  fi
}

# ── Profile seeding helper ──────────────────────────────────────────────────

# default/ mirrors a profile's layout: default/<rel> seeds to <profile>/<rel>.
# Seeds only missing files (never overwrites); cp -p carries the +x bit on hooks.
# find walks dotpaths correctly (a `cp default/*` glob would skip .claude/).
# $1 = profile dir; $2 = "verbose" to echo each seeded path.
seed_profile() {
  local profile_dir="$1" verbose="${2:-}" src rel dest
  while IFS= read -r src; do
    rel="${src#"$SCRIPT_DIR/default/"}"
    dest="$profile_dir/$rel"
    [[ -f "$dest" ]] && continue
    mkdir -p "$(dirname "$dest")"
    cp -p "$src" "$dest"
    [[ "$verbose" == verbose ]] && echo "Seeded $dest"
  done < <(find "$SCRIPT_DIR/default" -type f | sort)
  return 0
}

# ── Nested podman helpers ───────────────────────────────────────────────────

# The Containerfile block managed by --podman-enable / --podman-disable.
# Everything between the begin/end markers is owned by clause; --podman-disable
# deletes exactly that range. subuid/subgid 1:999 + 1001:64535 is the standard
# podman-in-podman layout for a uid-1000 user: it skips 1000 (already the
# user's own uid) and fits inside the ~65k uids the outer userns provides.
nested_containerfile_block() {
  cat <<'EOF'
# clause-nested-begin
USER root
RUN apt-get update && apt-get install -y \
    podman \
    uidmap \
    slirp4netns \
    fuse-overlayfs \
    podman-compose \
    && rm -rf /var/lib/apt/lists/* \
    && printf 'claude:1:999\nclaude:1001:64535\n' > /etc/subuid \
    && printf 'claude:1:999\nclaude:1001:64535\n' > /etc/subgid \
    && printf 'unqualified-search-registries = ["docker.io"]\n' > /etc/containers/registries.conf \
    && printf '[engine]\ncgroup_manager = "cgroupfs"\nevents_logger = "file"\n' >> /etc/containers/containers.conf
RUN arch="$(dpkg --print-architecture)" \
    && case "$arch" in amd64) larch=x86_64 ;; arm64) larch=arm64 ;; *) echo "unsupported arch: $arch" >&2; exit 1 ;; esac \
    && tag="$(curl -fsSLo /dev/null -w '%{url_effective}' https://github.com/jesseduffield/lazydocker/releases/latest)" \
    && tag="${tag##*/}" \
    && curl -fsSL "https://github.com/jesseduffield/lazydocker/releases/download/${tag}/lazydocker_${tag#v}_Linux_${larch}.tar.gz" \
       | tar -xz -C /usr/local/bin lazydocker
USER claude
RUN mkdir -p /home/claude/.local/share/containers
# lazydocker speaks the docker API; compose actions are mapped to podman-compose
RUN mkdir -p /home/claude/.config/lazydocker \
    && printf 'commandTemplates:\n  dockerCompose: podman-compose\n' > /home/claude/.config/lazydocker/config.yml
# lazydocker wrapper: start podman's API socket on demand, point DOCKER_HOST at it
# (alias ld shadows the binutils linker in interactive shells only)
RUN printf '%s\n' \
    '' \
    'lazydocker() {' \
    '  local sock' \
    '  sock="$(podman info --format "{{.Host.RemoteSocket.Path}}" 2>/dev/null)"' \
    '  sock="${sock#unix://}"' \
    '  if [ -z "$sock" ]; then' \
    '    echo "lazydocker: podman not available; nested podman must be enabled" >&2' \
    '    return 1' \
    '  fi' \
    '  if [ ! -S "$sock" ]; then' \
    '    (podman system service --time=0 >/dev/null 2>&1 &)' \
    '    local i=0' \
    '    while [ "$i" -lt 50 ] && [ ! -S "$sock" ]; do sleep 0.1; i=$((i+1)); done' \
    '  fi' \
    '  DOCKER_HOST="unix://$sock" command lazydocker "$@"' \
    '}' \
    "alias ld='lazydocker'" \
    >> /home/claude/.bashrc
# clause-nested-end
EOF
}

# ── Suggest-updates helpers ────────────────────────────────────────────────

# Print non-flag tokens that appear after the keyword in the given array.
# Usage: pkgs_after <keyword> <token...>
pkgs_after() {
  local keyword="$1"; shift
  local found=false tok
  for tok in "$@"; do
    if [[ "$found" == true && "$tok" != -* ]]; then
      echo "$tok"
    elif [[ "$tok" == "$keyword" ]]; then
      found=true
    fi
  done
}

# Render a RUN block for the given installer if its file has entries.
# Usage: render_block <file> <header> <footer>
render_block() {
  local file="$1" header="$2" footer="$3"
  [[ ! -s "$file" ]] && return 1
  local pkgs
  mapfile -t pkgs < <(sort -u "$file")
  echo "$header"
  local n=${#pkgs[@]} i
  for (( i=0; i<n-1; i++ )); do
    printf '    %s \\\n' "${pkgs[i]}"
  done
  printf '    %s' "${pkgs[n-1]}"
  if [[ -n "$footer" ]]; then
    printf ' \\\n%s\n' "$footer"
  else
    echo
  fi
  echo
  return 0
}

# ── Management: --build ──────────────────────────────────────────────────────

if [[ "$OPT_BUILD" == true ]]; then
  require_profile
  seed_profile "$PROFILE_DIR"
  "$CONTAINER_CLI" build --no-cache -t "clause-$PROFILE_NAME" "$PROFILE_DIR"
  exit 0
fi

# ── Management: --create-profile ───────────────────────────────────────────

if [[ "$OPT_CREATE_PROFILE" == true ]]; then
  PROFILE_NAME="$(profile_for_management)"
  PROFILE_DIR="$CLAUSE_DIR/profiles/$PROFILE_NAME"
  if [[ -d "$PROFILE_DIR" ]]; then
    echo "Error: profile '$PROFILE_NAME' already exists" >&2; exit 1
  fi
  prompt_yes "Create profile '$PROFILE_NAME'?" || { echo "Aborted."; exit 0; }
  init_profile_runtime "$PROFILE_DIR"
  echo "Created profile '$PROFILE_NAME'"
  seed_profile "$PROFILE_DIR" verbose
  config_set "$WORKSPACE" "$PROFILE_NAME"
  echo "Mapped $WORKSPACE → $PROFILE_NAME"
  exit 0
fi

# ── Management: --delete-profile ───────────────────────────────────────────

if [[ "$OPT_DELETE_PROFILE" == true ]]; then
  require_profile
  if [[ "$PROFILE_NAME" == "default" ]]; then
    echo "Error: cannot delete the default profile" >&2; exit 1
  fi
  confirm_yes "Delete profile '$PROFILE_NAME' and all its data?" || { echo "Aborted."; exit 0; }
  rm -rf "$PROFILE_DIR"
  if image_exists "clause-$PROFILE_NAME"; then
    "$CONTAINER_CLI" rmi "clause-$PROFILE_NAME" >/dev/null 2>&1 || true
    echo "Removed image 'clause-$PROFILE_NAME'"
  fi
  if volume_exists "clause-$PROFILE_NAME-containers"; then
    "$CONTAINER_CLI" volume rm "clause-$PROFILE_NAME-containers" >/dev/null 2>&1 || true
    echo "Removed volume 'clause-$PROFILE_NAME-containers'"
  fi
  COUNT=$(config_del_by_profile "$PROFILE_NAME")
  [[ "$COUNT" -gt 0 ]] && echo "Removed ${COUNT} mapping(s) for profile '$PROFILE_NAME'"
  echo "Deleted profile '$PROFILE_NAME'"
  exit 0
fi

# ── Management: -l / --list ────────────────────────────────────────────────

if [[ "$OPT_LIST" == true ]]; then
  CURRENT_MAPPING="$(config_get "$WORKSPACE")"
  if [[ -n "$CURRENT_MAPPING" ]]; then
    echo "$WORKSPACE → $CURRENT_MAPPING"
  else
    echo "$WORKSPACE → (no mapping)"
  fi
  echo
  echo "profiles:"
  shopt -s nullglob
  FOUND=false
  for d in "$CLAUSE_DIR/profiles"/*/; do
    if [[ -f "$d/nested" ]]; then
      echo "  $(basename "$d") (nested)"
    else
      echo "  $(basename "$d")"
    fi
    FOUND=true
  done
  shopt -u nullglob
  [[ "$FOUND" == false ]] && echo "  (no profiles)"
  exit 0
fi

# ── Management: -L / --list-all ────────────────────────────────────────────

if [[ "$OPT_LIST_ALL" == true ]]; then
  if [[ ! -s "$CONF_FILE" ]]; then
    echo "(no mappings)"
  else
    cat "$CONF_FILE"
  fi
  exit 0
fi

# ── Management: --reset-containerfile ──────────────────────────────────────

if [[ "$OPT_RESET_CONTAINERFILE" == true ]]; then
  require_profile
  prompt_yes "Reset Containerfile for profile '$PROFILE_NAME' from default?" || { echo "Aborted."; exit 0; }
  cp -f "$SCRIPT_DIR/default/Containerfile" "$PROFILE_DIR/Containerfile"
  echo "Reset $PROFILE_DIR/Containerfile from default"
  if [[ -f "$PROFILE_DIR/nested" ]]; then
    echo "Note: nested podman is enabled but the reset removed its Containerfile block."
    echo "Re-add it with: clause $PROFILE_NAME --podman-enable"
  fi
  exit 0
fi

# ── Management: --args-set-profile ─────────────────────────────────────────

if [[ "$OPT_ARGS_SET_PROFILE_GIVEN" == true ]]; then
  require_profile
  echo "$OPT_ARGS_SET_PROFILE" > "$PROFILE_DIR/clause-args"
  echo "Wrote $PROFILE_DIR/clause-args: $OPT_ARGS_SET_PROFILE"
  exit 0
fi

# ── Management: --args-set ─────────────────────────────────────────────────

if [[ "$OPT_ARGS_SET_GIVEN" == true ]]; then
  echo "$OPT_ARGS_SET" > "$WORKSPACE/.clause-args"
  echo "Wrote $WORKSPACE/.clause-args: $OPT_ARGS_SET"
  exit 0
fi

# ── Management: -A / --args-view ───────────────────────────────────────────

if [[ "$OPT_ARGS_VIEW" == true ]]; then
  require_profile
  resolve_args
  if [[ -n "$ARGS_SOURCE" ]]; then
    echo "$ARGS_LINE"
    echo "(source: $ARGS_SOURCE)"
  else
    echo "(no args)"
  fi
  exit 0
fi

# ── Management: --suggest-updates ──────────────────────────────────────────

if [[ "$OPT_SUGGEST_UPDATES" == true ]]; then
  require_profile
  LOG="$PROFILE_DIR/.claude/clause-sudo.log"
  if [[ ! -f "$LOG" ]]; then
    echo "No sudo log found at $LOG"; exit 0
  fi

  if [[ -f "$PROFILE_DIR/Containerfile" ]]; then
    TARGET="$PROFILE_DIR/Containerfile"
    TARGET_NOTE="profile Containerfile: $TARGET"
  else
    TARGET="$SCRIPT_DIR/default/Containerfile"
    TARGET_NOTE="default Containerfile (profile has no Containerfile; reset with: clause $PROFILE_NAME --reset-containerfile)"
  fi

  TMP=$(mktemp -d)
  trap 'rm -rf "$TMP"' EXIT

  # Extract every COMMAND= payload from the sudo log
  # Sudo wraps long log lines at column 80 with 4-space-indented continuations;
  # join them back together before extracting the COMMAND= payload.
  sed ':a;N;$!ba;s/\n[[:space:]]\+/ /g' "$LOG" | awk -F' ; COMMAND=' 'NF>1 {print $2}' | while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    read -ra T <<< "$line"
    cmd="${T[0]##*/}"
    case "$cmd" in
      apt|apt-get)
        pkgs_after install "${T[@]:1}" >> "$TMP/apt"
        ;;
      npm)
        # only -g / --global installs
        if printf '%s\n' "${T[@]:1}" | grep -qxE -- '-g|--global'; then
          pkgs_after install "${T[@]:1}" >> "$TMP/npm"
          pkgs_after i       "${T[@]:1}" >> "$TMP/npm"
        fi
        ;;
      pip|pip3)
        # skip --user installs (those go to ~/.local, not the image)
        if ! printf '%s\n' "${T[@]:1}" | grep -qx -- '--user'; then
          pkgs_after install "${T[@]:1}" >> "$TMP/pip"
        fi
        ;;
      gem)   pkgs_after install "${T[@]:1}" >> "$TMP/gem" ;;
      cargo) pkgs_after install "${T[@]:1}" >> "$TMP/cargo" ;;
      snap)  pkgs_after install "${T[@]:1}" >> "$TMP/snap" ;;
    esac
  done

  # Filter out packages already named in the target Containerfile (substring match)
  for f in "$TMP"/*; do
    [[ -f "$f" ]] || continue
    grep -vFf <(grep -oE '[a-zA-Z0-9_.+@/-]+' "$TARGET" | sort -u) "$f" > "$f.new" || true
    mv "$f.new" "$f"
  done

  echo "# Containerfile suggestions for profile '$PROFILE_NAME'"
  echo "# Source log: $LOG"
  echo "# Target:     $TARGET_NOTE"
  echo

  any=false
  render_block "$TMP/apt" \
    "RUN apt-get update && apt-get install -y \\" \
    "    && rm -rf /var/lib/apt/lists/*" && any=true
  render_block "$TMP/npm"   "RUN npm install -g \\"    "" && any=true
  render_block "$TMP/pip"   "RUN pip install --no-cache-dir \\" "" && any=true
  render_block "$TMP/gem"   "RUN gem install \\"       "" && any=true
  render_block "$TMP/cargo" "RUN cargo install \\"     "" && any=true
  render_block "$TMP/snap"  "RUN snap install \\"      "" && any=true

  if [[ "$any" == false ]]; then
    echo "# No new installs detected (log empty or all packages already present in target)."
  else
    echo "# To apply: append the relevant blocks to $TARGET, then: clause $PROFILE_NAME -b"
  fi
  exit 0
fi

# ── Management: --podman-enable ────────────────────────────────────────────

if [[ "$OPT_PODMAN_ENABLE" == true ]]; then
  require_profile
  seed_profile "$PROFILE_DIR"
  if [[ -f "$PROFILE_DIR/nested" ]]; then
    echo "Nested podman already enabled for profile '$PROFILE_NAME'"
  else
    touch "$PROFILE_DIR/nested"
    echo "Enabled nested podman for profile '$PROFILE_NAME'"
  fi
  if grep -qF '# clause-nested-begin' "$PROFILE_DIR/Containerfile"; then
    echo "Containerfile already contains the nested podman block"
  else
    if prompt_yes "Append nested podman block to $PROFILE_DIR/Containerfile?"; then
      printf '\n' >> "$PROFILE_DIR/Containerfile"
      nested_containerfile_block >> "$PROFILE_DIR/Containerfile"
      echo "Appended nested podman block to $PROFILE_DIR/Containerfile"
    else
      echo "Skipped. Add this block to $PROFILE_DIR/Containerfile manually:"
      echo
      nested_containerfile_block
    fi
  fi
  echo "Rebuild the image to apply: clause $PROFILE_NAME -b"
  exit 0
fi

# ── Management: --podman-disable ───────────────────────────────────────────

if [[ "$OPT_PODMAN_DISABLE" == true ]]; then
  require_profile
  if [[ -f "$PROFILE_DIR/nested" ]]; then
    rm "$PROFILE_DIR/nested"
    echo "Disabled nested podman for profile '$PROFILE_NAME'"
  else
    echo "Nested podman is not enabled for profile '$PROFILE_NAME'"
  fi
  if [[ -f "$PROFILE_DIR/Containerfile" ]] && grep -qF '# clause-nested-begin' "$PROFILE_DIR/Containerfile"; then
    if prompt_yes "Remove nested podman block from $PROFILE_DIR/Containerfile?"; then
      sed -i '/^# clause-nested-begin$/,/^# clause-nested-end$/d' "$PROFILE_DIR/Containerfile"
      # trim the separator blank line(s) --podman-enable added before the block
      while [[ "$(wc -c < "$PROFILE_DIR/Containerfile")" -gt 1 && -z "$(tail -c 2 "$PROFILE_DIR/Containerfile")" ]]; do
        truncate -s -1 "$PROFILE_DIR/Containerfile"
      done
      echo "Removed nested podman block (rebuild to slim the image: clause $PROFILE_NAME -b)"
    else
      echo "Kept nested podman block (its packages are inert without the launch flags)"
    fi
  fi
  echo "Note: the storage volume 'clause-$PROFILE_NAME-containers' is kept, if present."
  echo "Remove it with: clause $PROFILE_NAME --podman-reset"
  exit 0
fi

# ── Management: --podman-reset ─────────────────────────────────────────────

if [[ "$OPT_PODMAN_RESET" == true ]]; then
  PROFILE_NAME="$(profile_for_management)"
  VOLUME_NAME="clause-$PROFILE_NAME-containers"
  if ! volume_exists "$VOLUME_NAME"; then
    echo "No nested podman storage volume found for profile '$PROFILE_NAME'"
    exit 0
  fi
  confirm_yes "Remove volume '$VOLUME_NAME'? This deletes all inner images, containers, and volumes (including any data in them)." || { echo "Aborted."; exit 0; }
  "$CONTAINER_CLI" volume rm "$VOLUME_NAME" >/dev/null
  echo "Removed volume '$VOLUME_NAME'. It will be recreated empty on the next nested launch."
  exit 0
fi

# ── Management: --alias-create ─────────────────────────────────────────────

ALIAS_LINE="alias clause='$SCRIPT_DIR/clause' # clause-alias"

if [[ "$OPT_CREATE_ALIAS" == true ]]; then
  ALIAS_ADDED=false
  for RC in "$HOME/.bashrc" "$HOME/.zshrc"; do
    if [[ ! -f "$RC" ]]; then
      echo "Skipping $RC (not found)"
      continue
    fi
    if grep -qF '# clause-alias' "$RC"; then
      echo "Alias already exists in $RC"
      continue
    fi
    prompt_yes "Add clause alias to $RC?" || continue
    echo "" >> "$RC"
    echo "$ALIAS_LINE" >> "$RC"
    echo "Added alias to $RC"
    ALIAS_ADDED=true
  done
  [[ "$ALIAS_ADDED" == false ]] && echo "No alias added."
  exit 0
fi

# ── Management: --alias-delete ─────────────────────────────────────────────

if [[ "$OPT_DELETE_ALIAS" == true ]]; then
  for RC in "$HOME/.bashrc" "$HOME/.zshrc"; do
    [[ ! -f "$RC" ]] && continue
    if ! grep -qF '# clause-alias' "$RC"; then
      echo "No alias found in $RC"
      continue
    fi
    confirm_yes "Remove clause alias from $RC?" || { echo "Aborted."; continue; }
    sed -i '/# clause-alias$/d' "$RC"
    echo "Removed alias from $RC"
  done
  exit 0
fi

# ── Management: --runtime-set ──────────────────────────────────────────────

if [[ -n "$OPT_SET_RUNTIME" ]]; then
  if [[ "$OPT_SET_RUNTIME" != "podman" && "$OPT_SET_RUNTIME" != "docker" ]]; then
    echo "Error: invalid runtime '$OPT_SET_RUNTIME'. Must be 'podman' or 'docker'" >&2; exit 1
  fi
  if ! command -v "$OPT_SET_RUNTIME" &>/dev/null; then
    echo "Error: '$OPT_SET_RUNTIME' not found on PATH" >&2; exit 1
  fi
  if [[ -f "$RUNTIME_FILE" ]]; then
    EXISTING_RUNTIME="$(tr -d '[:space:]' < "$RUNTIME_FILE")"
    prompt_yes "Runtime already set to '$EXISTING_RUNTIME'. Override with '$OPT_SET_RUNTIME'?" || { echo "Aborted."; exit 0; }
  fi
  echo "$OPT_SET_RUNTIME" > "$RUNTIME_FILE"
  echo "Runtime set to '$OPT_SET_RUNTIME' ($RUNTIME_FILE)"
  exit 0
fi

# ── Management: --runtime-remove ───────────────────────────────────────────

if [[ "$OPT_REMOVE_RUNTIME" == true ]]; then
  if [[ ! -f "$RUNTIME_FILE" ]]; then
    echo "Error: no runtime override is set" >&2; exit 1
  fi
  confirm_yes "Remove runtime override?" || { echo "Aborted."; exit 0; }
  rm "$RUNTIME_FILE"
  echo "Runtime override removed. Auto-detection will be used."
  exit 0
fi

# ── Management: -m / --map ─────────────────────────────────────────────────

if [[ "$OPT_MAP" == true ]]; then
  require_profile "${OPT_PROFILE:-default}"
  EXISTING="$(config_get "$WORKSPACE")"
  if [[ -n "$EXISTING" ]]; then
    echo "Warning: $WORKSPACE is already mapped to '$EXISTING'"
    prompt_yes "Overwrite with '$PROFILE_NAME'?" || { echo "Aborted."; exit 0; }
  fi
  config_set "$WORKSPACE" "$PROFILE_NAME"
  echo "Mapped $WORKSPACE → $PROFILE_NAME"
  exit 0
fi

# ── Management: -u / --unmap ───────────────────────────────────────────────

if [[ "$OPT_UNMAP" == true ]]; then
  SAVED="$(config_get "$WORKSPACE")"
  if [[ -z "$SAVED" ]]; then
    echo "Error: no mapping found for $WORKSPACE" >&2; exit 1
  fi
  if prompt_yes "Remove mapping $WORKSPACE → $SAVED?"; then
    config_del "$WORKSPACE"
    echo "Removed mapping: $WORKSPACE → $SAVED"
  else
    echo "Aborted."
  fi
  exit 0
fi

# ── Resolve profile ─────────────────────────────────────────────────────────

REQUESTED="${OPT_PROFILE:-default}"
SAVED="$(config_get "$WORKSPACE")"
PROMPT_REPLY=""

if [[ -n "$SAVED" && -z "$OPT_PROFILE" ]]; then
  PROFILE_NAME="$SAVED"
elif [[ -z "$SAVED" || "$SAVED" != "$REQUESTED" ]]; then
  if [[ -z "$SAVED" ]]; then
    MSG="No mapping found. Save $WORKSPACE → $REQUESTED?"
  else
    MSG="Workspace mapped to '$SAVED'. Override with '$REQUESTED'?"
  fi
  prompt_ynq "$MSG"
  case "$PROMPT_REPLY" in
    y|Y)
      config_set "$WORKSPACE" "$REQUESTED"
      PROFILE_NAME="$REQUESTED"
      ;;
    n|N)
      PROFILE_NAME="${SAVED:-$REQUESTED}"
      ;;
    *)
      echo "Aborted."; exit 0
      ;;
  esac
else
  PROFILE_NAME="$SAVED"
fi

# ── Verify profile exists ───────────────────────────────────────────────────

require_profile "$PROFILE_NAME"

# ── Init profile runtime data ───────────────────────────────────────────────

init_profile_runtime "$PROFILE_DIR"
seed_profile "$PROFILE_DIR"

# ── Ensure image exists ─────────────────────────────────────────────────────

IMAGE_NAME="clause-$PROFILE_NAME"
if ! image_exists "$IMAGE_NAME"; then
  echo "Error: '$IMAGE_NAME' image not found. Build it with: clause $PROFILE_NAME --build" >&2
  exit 1
fi

# ── Resolve container command ───────────────────────────────────────────────

if [[ "$OPT_T" == true ]]; then
  CONTAINER_CMD=(bash)
else
  CONTAINER_CMD=(claude)
  resolve_args
  if [[ -n "$ARGS_LINE" ]]; then
    read -ra ARGS_ARRAY <<< "$ARGS_LINE"
    CONTAINER_CMD+=("${ARGS_ARRAY[@]}")
  fi
fi

# ── Launch container ────────────────────────────────────────────────────────

CONTAINER_NAME="clause-$$"

cleanup() {
  "$CONTAINER_CLI" stop "$CONTAINER_NAME" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

USER_FLAGS=()
if [[ "$CONTAINER_CLI" == "podman" ]]; then
  USER_FLAGS+=(--userns=keep-id:uid=1000,gid=1000)
else
  USER_FLAGS+=(--user "$(id -u):$(id -g)")
fi

# Nested podman: the devices and relaxations rootless podman needs inside the
# session, plus a named volume so inner images survive the ephemeral container.
# A volume (not a profile bind mount) keeps nested-subuid-owned files out of
# the profile dir (plain rm -rf could not delete them) and, living outside the
# container's overlay rootfs, lets inner storage use native overlayfs.
NESTED_FLAGS=()
if [[ -f "$PROFILE_DIR/nested" ]]; then
  NESTED_FLAGS+=(-v "clause-$PROFILE_NAME-containers:/home/claude/.local/share/containers")
  if [[ -e /dev/fuse ]]; then
    NESTED_FLAGS+=(--device /dev/fuse)
  else
    echo "Warning: /dev/fuse not found on host; nested podman storage may fall back to vfs" >&2
  fi
  if [[ -e /dev/net/tun ]]; then
    NESTED_FLAGS+=(--device /dev/net/tun)
  else
    echo "Warning: /dev/net/tun not found on host; nested container networking will be limited" >&2
  fi
  NESTED_FLAGS+=(--security-opt label=disable)
  if [[ "$CONTAINER_CLI" == "docker" ]]; then
    # docker's default seccomp/apparmor profiles block syscalls nested podman
    # needs (unshare, mount); podman's defaults allow them
    NESTED_FLAGS+=(--security-opt seccomp=unconfined --security-opt apparmor=unconfined)
  fi
  if [[ ! -f "$PROFILE_DIR/Containerfile" ]] || ! grep -qi podman "$PROFILE_DIR/Containerfile"; then
    echo "Warning: nested podman is enabled but $PROFILE_DIR/Containerfile does not appear to install podman." >&2
    echo "Fix with: clause $PROFILE_NAME --podman-enable  (then rebuild: clause $PROFILE_NAME -b)" >&2
  fi
fi

# Encode host workspace path the same way Claude encodes its project keys
# (`/` and `.` → `-`) so each host workspace gets a distinct cwd inside the
# container — keeps Claude's per-project state under ~/.claude/projects/
# separated when multiple workspaces share a profile.
ENCODED_WORKSPACE="${WORKSPACE//\//-}"
ENCODED_WORKSPACE="${ENCODED_WORKSPACE//./-}"
CONTAINER_WORKSPACE="/workspace/$ENCODED_WORKSPACE"

"$CONTAINER_CLI" run --rm -it --name "$CONTAINER_NAME" \
  "${USER_FLAGS[@]}" \
  "${NESTED_FLAGS[@]}" \
  -v "$PROFILE_DIR/.claude:/home/claude/.claude" \
  -v "$PROFILE_DIR/.claude.json:/home/claude/.claude.json" \
  -v "$PROFILE_DIR/.gitconfig:/home/claude/.gitconfig" \
  -v "$WORKSPACE:$CONTAINER_WORKSPACE" \
  -e "TERM=xterm-256color" \
  -w "$CONTAINER_WORKSPACE" \
  "$IMAGE_NAME" \
  "${CONTAINER_CMD[@]}"
