#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"

# Parse flags
USE_DEFAULT=false
TERMINAL_MODE=false
while getopts "yt" opt; do
  case $opt in
    y) USE_DEFAULT=true ;;
    t) TERMINAL_MODE=true ;;
    *) echo "usage: clause [-y] [-t] [profile]" >&2; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

# Resolve profile
PROFILE="${1:-$(basename "$PWD")}"
PROFILE_DIR="$SCRIPT_DIR/profiles/$PROFILE"

# Fallback to default if profile not found
if [[ ! -d "$PROFILE_DIR" ]]; then
  if [[ "$USE_DEFAULT" == true ]]; then
    PROFILE_DIR="$SCRIPT_DIR/profiles/default"
  else
    read -r -n 1 -p "Profile '$PROFILE' not found. Use default? [y/N] " REPLY
    echo
    if [[ "$REPLY" == "y" || "$REPLY" == "Y" ]]; then
      PROFILE_DIR="$SCRIPT_DIR/profiles/default"
    else
      exit 1
    fi
  fi
fi

# Init profile data dirs
mkdir -p "$PROFILE_DIR/.claude"
touch "$PROFILE_DIR/.claude.json"

CONTAINER_NAME="clause-$$"

cleanup() {
  podman stop "$CONTAINER_NAME" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

# Determine container command
if [[ "$TERMINAL_MODE" == true ]]; then
  CONTAINER_CMD="bash"
else
  CONTAINER_CMD="claude"
fi

podman run --rm -it --name "$CONTAINER_NAME" \
  -v "$PROFILE_DIR/.claude:/root/.claude" \
  -v "$PROFILE_DIR/.claude.json:/root/.claude.json" \
  -v "$PWD:/workspace" \
  -w /workspace \
  clause \
  "$CONTAINER_CMD"
