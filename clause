#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLAUSE_DIR="$HOME/.clause"
CONF_FILE="$CLAUSE_DIR/clause.conf"
RUNTIME_FILE="$CLAUSE_DIR/runtime"

usage() {
  cat <<'EOF'
usage: clause [-h] [profile] [options]

arguments:
  profile                 Profile to use (default: 'default')

session options:
  -w, --workspace <path>  Workspace directory (default: $PWD)
  -t, --terminal          Launch bash instead of claude

prompt options:
  -y, --yes               Auto-answer yes to all prompts
  -n, --no                Auto-answer no to all prompts

mapping (then exit):
  -a, --add               Add workspace→profile mapping
  -r, --remove            Remove workspace→profile mapping
  -l, --list              Show current mapping and list all profiles
  -L, --list-all          List all workspace→profile mappings

profile management (then exit):
  -C, --create-profile        Create a new profile (Containerfile + args.env seeded)
  -D, --delete-profile        Delete a profile and remove its mappings
  -R, --reset-containerfile   Overwrite profile Containerfile with default
  -S, --suggest-updates       Suggest Containerfile updates from sudo log

arguments (then exit):
  -A, --args <value>      Set claude args for profile (writes args.env)
                          Default: agents --effort max --dangerously-skip-permissions

alias management (then exit):
  --alias-create          Add clause alias to .bashrc and/or .zshrc
  --alias-delete          Remove clause alias from .bashrc and/or .zshrc

runtime management (then exit):
  --runtime-set <value>   Set container runtime override (podman or docker)
  --runtime-remove        Remove container runtime override

other:
  -b, --build             Build the container image
  -h, --help              Print this help
EOF
}

# ── Argument parsing ────────────────────────────────────────────────────────

OPT_CREATE_PROFILE=false
OPT_DELETE_PROFILE=false
OPT_RESET_CONTAINERFILE=false
OPT_SET_ARGS=""
OPT_SET_ARGS_GIVEN=false
OPT_SUGGEST_UPDATES=false
OPT_LIST=false
OPT_LIST_ALL=false
OPT_CREATE_ALIAS=false
OPT_DELETE_ALIAS=false
OPT_SET_RUNTIME=""
OPT_REMOVE_RUNTIME=false
OPT_BUILD=false
OPT_Y=false
OPT_N=false
OPT_T=false
OPT_R=false
OPT_A=false
OPT_PROFILE=""
OPT_W=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -C|--create-profile) OPT_CREATE_PROFILE=true; shift ;;
    -D|--delete-profile) OPT_DELETE_PROFILE=true; shift ;;
    -R|--reset-containerfile) OPT_RESET_CONTAINERFILE=true; shift ;;
    -A|--args)
      [[ $# -lt 2 ]] && { echo "Error: $1 requires a string value" >&2; exit 1; }
      OPT_SET_ARGS="$2"
      OPT_SET_ARGS_GIVEN=true
      shift 2
      ;;
    -S|--suggest-updates) OPT_SUGGEST_UPDATES=true; shift ;;
    -l|--list) OPT_LIST=true; shift ;;
    -L|--list-all) OPT_LIST_ALL=true; shift ;;
    --alias-create) OPT_CREATE_ALIAS=true; shift ;;
    --alias-delete) OPT_DELETE_ALIAS=true; shift ;;
    --runtime-set)
      [[ $# -lt 2 ]] && { echo "Error: --runtime-set requires a value (podman or docker)" >&2; exit 1; }
      OPT_SET_RUNTIME="$2"
      shift 2
      ;;
    --runtime-remove) OPT_REMOVE_RUNTIME=true; shift ;;
    -b|--build) OPT_BUILD=true; shift ;;
    -h|--help) usage; exit 0 ;;
    -y|--yes) OPT_Y=true; shift ;;
    -n|--no) OPT_N=true; shift ;;
    -t|--terminal) OPT_T=true; shift ;;
    -r|--remove) OPT_R=true; shift ;;
    -a|--add) OPT_A=true; shift ;;
    -w|--workspace)
      [[ $# -lt 2 ]] && { echo "Error: $1 requires a path" >&2; exit 1; }
      OPT_W="$2"
      shift 2
      ;;
    -*)
      echo "Error: unknown option '$1'" >&2; usage >&2; exit 1
      ;;
    *)
      if [[ -n "$OPT_PROFILE" ]]; then
        echo "Error: unexpected argument '$1'" >&2; usage >&2; exit 1
      fi
      OPT_PROFILE="${1,,}"
      shift
      ;;
  esac
done

# ── Mutual exclusivity checks ───────────────────────────────────────────────

if [[ "$OPT_Y" == true && "$OPT_N" == true ]]; then
  echo "Error: -y and -n are mutually exclusive" >&2; exit 1
fi

MGMT_COUNT=0
[[ "$OPT_CREATE_PROFILE" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_DELETE_PROFILE" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_RESET_CONTAINERFILE" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_SET_ARGS_GIVEN" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_SUGGEST_UPDATES" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_LIST" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_LIST_ALL" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_A" == true ]] && (( ++MGMT_COUNT ))
[[ "$OPT_R" == true ]] && (( ++MGMT_COUNT ))
if [[ "$MGMT_COUNT" -gt 1 ]]; then
  echo "Error: mapping/profile management options are mutually exclusive" >&2; exit 1
fi

if [[ "$OPT_CREATE_ALIAS" == true && "$OPT_DELETE_ALIAS" == true ]]; then
  echo "Error: --alias-create and --alias-delete are mutually exclusive" >&2; exit 1
fi

if [[ -n "$OPT_SET_RUNTIME" && "$OPT_REMOVE_RUNTIME" == true ]]; then
  echo "Error: --runtime-set and --runtime-remove are mutually exclusive" >&2; exit 1
fi

# ── Resolve workspace ───────────────────────────────────────────────────────

if [[ -n "$OPT_W" ]]; then
  if [[ ! -d "$OPT_W" ]]; then
    echo "Error: workspace '$OPT_W' is not a directory" >&2; exit 1
  fi
  WORKSPACE="$(realpath "$OPT_W")"
else
  WORKSPACE="$(realpath "$PWD")"
fi

# ── Bootstrap ~/.clause layout (skipped for read-only -l/-L) ───────────────

if [[ "$OPT_LIST" != true && "$OPT_LIST_ALL" != true ]]; then
  mkdir -p "$CLAUSE_DIR/profiles/default/.claude"
  [[ ! -f "$CLAUSE_DIR/profiles/default/.claude.json" ]] && echo '{}' > "$CLAUSE_DIR/profiles/default/.claude.json"
  touch "$CLAUSE_DIR/profiles/default/.gitconfig"
  touch "$CONF_FILE"
fi

# ── Detect container runtime (skipped for read-only -l/-L) ─────────────────

if [[ "$OPT_LIST" != true && "$OPT_LIST_ALL" != true ]]; then
  if [[ -f "$RUNTIME_FILE" ]]; then
    CONTAINER_CLI="$(tr -d '[:space:]' < "$RUNTIME_FILE")"
    if [[ -z "$CONTAINER_CLI" ]]; then
      echo "Error: $RUNTIME_FILE is empty; remove it or run: clause --runtime-set podman" >&2; exit 1
    fi
    if [[ "$CONTAINER_CLI" != "podman" && "$CONTAINER_CLI" != "docker" ]]; then
      echo "Error: invalid runtime '$CONTAINER_CLI' in $RUNTIME_FILE. Must be 'podman' or 'docker'" >&2; exit 1
    fi
    if ! command -v "$CONTAINER_CLI" &>/dev/null; then
      echo "Error: runtime '$CONTAINER_CLI' set in $RUNTIME_FILE but not found on PATH" >&2; exit 1
    fi
  elif command -v podman &>/dev/null; then
    CONTAINER_CLI="podman"
  elif command -v docker &>/dev/null; then
    CONTAINER_CLI="docker"
  else
    echo "Error: neither podman nor docker found on PATH" >&2; exit 1
  fi
fi

# ── Config helpers ──────────────────────────────────────────────────────────

config_get() {
  local workspace="$1"
  [[ ! -f "$CONF_FILE" ]] && echo "" && return
  awk -F= -v ws="$workspace" '$1 == ws { print $2; exit }' "$CONF_FILE" || echo ""
}

config_set() {
  local workspace="$1" profile="$2"
  config_del "$workspace"
  echo "${workspace}=${profile}" >> "$CONF_FILE"
}

config_del() {
  local workspace="$1"
  [[ ! -f "$CONF_FILE" ]] && return
  awk -F= -v ws="$workspace" '$1 != ws' "$CONF_FILE" > "${CONF_FILE}.tmp"
  mv "${CONF_FILE}.tmp" "$CONF_FILE"
}

config_del_by_profile() {
  local profile="$1"
  [[ ! -f "$CONF_FILE" ]] && echo "0" && return
  local count
  count=$(awk -F= -v p="$profile" '$2 == p { c++ } END { print c+0 }' "$CONF_FILE")
  awk -F= -v p="$profile" '$2 != p' "$CONF_FILE" > "${CONF_FILE}.tmp"
  mv "${CONF_FILE}.tmp" "$CONF_FILE"
  echo "$count"
}

# ── Session helpers ─────────────────────────────────────────────────────────

session_get() {
  local f="$WORKSPACE/.clause-session-id"
  [[ -f "$f" ]] && tr -d '[:space:]' < "$f" || echo ""
}

session_del() {
  rm -f "$WORKSPACE/.clause-session-id"
}

# ── Container helpers ───────────────────────────────────────────────────────

image_exists() {
  "$CONTAINER_CLI" image inspect "$1" &>/dev/null
}

# ── Prompt helpers ──────────────────────────────────────────────────────────

# Sets global PROMPT_REPLY to y, n, or q
prompt_ynq() {
  local message="$1"
  if [[ "$OPT_Y" == true ]]; then
    echo "${message} [y/n/q] y"
    PROMPT_REPLY="y"
    return
  fi
  if [[ "$OPT_N" == true ]]; then
    echo "${message} [y/n/q] n"
    PROMPT_REPLY="n"
    return
  fi
  read -r -n 1 -p "${message} [y/n/q] " PROMPT_REPLY
  echo
}

# Prompts for literal "yes"; returns 1 (false) if not confirmed
confirm_yes() {
  local message="$1"
  local reply
  read -r -p "${message} Type 'yes' to confirm: " reply
  [[ "$reply" == "yes" ]]
}

# ── Profile resolution helper (silent, for management commands) ─────────────

profile_for_management() {
  local saved
  saved="$(config_get "$WORKSPACE")"
  echo "${OPT_PROFILE:-${saved:-default}}"
}

# ── Management: --build ──────────────────────────────────────────────────────

if [[ "$OPT_BUILD" == true ]]; then
  BUILD_PROFILE="$(profile_for_management)"
  BUILD_PROFILE_DIR="$CLAUSE_DIR/profiles/$BUILD_PROFILE"
  if [[ -f "$BUILD_PROFILE_DIR/Containerfile" ]]; then
    "$CONTAINER_CLI" build --no-cache -t "clause-$BUILD_PROFILE" "$BUILD_PROFILE_DIR"
  else
    "$CONTAINER_CLI" build --no-cache -f "$SCRIPT_DIR/defaults/Containerfile" -t clause "$SCRIPT_DIR"
  fi
  exit 0
fi

# ── Management: --create-profile ───────────────────────────────────────────

if [[ "$OPT_CREATE_PROFILE" == true ]]; then
  PROFILE_NAME="$(profile_for_management)"
  PROFILE_DIR="$CLAUSE_DIR/profiles/$PROFILE_NAME"
  if [[ -d "$PROFILE_DIR" ]]; then
    echo "Error: profile '$PROFILE_NAME' already exists" >&2; exit 1
  fi
  prompt_ynq "Create profile '$PROFILE_NAME'?"
  [[ "$PROMPT_REPLY" =~ ^[yY]$ ]] || { echo "Aborted."; exit 0; }
  mkdir -p "$PROFILE_DIR/.claude"
  touch "$PROFILE_DIR/.gitconfig"
  cp "$SCRIPT_DIR/defaults/Containerfile" "$PROFILE_DIR/Containerfile"
  cp "$SCRIPT_DIR/defaults/args.env" "$PROFILE_DIR/args.env"
  echo "Created profile '$PROFILE_NAME'"
  echo "Seeded $PROFILE_DIR/Containerfile"
  echo "Seeded $PROFILE_DIR/args.env"
  config_set "$WORKSPACE" "$PROFILE_NAME"
  echo "Mapped $WORKSPACE → $PROFILE_NAME"
  exit 0
fi

# ── Management: --delete-profile ───────────────────────────────────────────

if [[ "$OPT_DELETE_PROFILE" == true ]]; then
  PROFILE_NAME="$(profile_for_management)"
  if [[ "$PROFILE_NAME" == "default" ]]; then
    echo "Error: cannot delete the default profile" >&2; exit 1
  fi
  PROFILE_DIR="$CLAUSE_DIR/profiles/$PROFILE_NAME"
  if [[ ! -d "$PROFILE_DIR" ]]; then
    echo "Error: profile '$PROFILE_NAME' does not exist" >&2; exit 1
  fi
  [[ "$OPT_N" == true ]] && { echo "Aborted."; exit 0; }
  confirm_yes "Delete profile '$PROFILE_NAME' and all its data?" || { echo "Aborted."; exit 0; }
  rm -rf "$PROFILE_DIR"
  if image_exists "clause-$PROFILE_NAME"; then
    "$CONTAINER_CLI" rmi "clause-$PROFILE_NAME" >/dev/null 2>&1 || true
    echo "Removed image 'clause-$PROFILE_NAME'"
  fi
  COUNT=$(config_del_by_profile "$PROFILE_NAME")
  [[ "$COUNT" -gt 0 ]] && echo "Removed ${COUNT} mapping(s) for profile '$PROFILE_NAME'"
  echo "Deleted profile '$PROFILE_NAME'"
  exit 0
fi

# ── Management: -l / --list ────────────────────────────────────────────────

if [[ "$OPT_LIST" == true ]]; then
  CURRENT_MAPPING="$(config_get "$WORKSPACE")"
  if [[ -n "$CURRENT_MAPPING" ]]; then
    echo "$WORKSPACE → $CURRENT_MAPPING"
  else
    echo "$WORKSPACE → (no mapping)"
  fi
  echo
  echo "profiles:"
  shopt -s nullglob
  FOUND=false
  for d in "$CLAUSE_DIR/profiles"/*/; do
    echo "  $(basename "$d")"
    FOUND=true
  done
  shopt -u nullglob
  [[ "$FOUND" == false ]] && echo "  (no profiles)"
  exit 0
fi

# ── Management: -L / --list-all ────────────────────────────────────────────

if [[ "$OPT_LIST_ALL" == true ]]; then
  if [[ ! -s "$CONF_FILE" ]]; then
    echo "(no mappings)"
  else
    cat "$CONF_FILE"
  fi
  exit 0
fi

# ── Management: --reset-containerfile ──────────────────────────────────────

if [[ "$OPT_RESET_CONTAINERFILE" == true ]]; then
  PROFILE_NAME="$(profile_for_management)"
  PROFILE_DIR="$CLAUSE_DIR/profiles/$PROFILE_NAME"
  if [[ ! -d "$PROFILE_DIR" ]]; then
    echo "Error: profile '$PROFILE_NAME' does not exist. Create it with: clause $PROFILE_NAME --create-profile" >&2; exit 1
  fi
  prompt_ynq "Reset Containerfile for profile '$PROFILE_NAME' from default?"
  [[ "$PROMPT_REPLY" =~ ^[yY]$ ]] || { echo "Aborted."; exit 0; }
  cp -f "$SCRIPT_DIR/defaults/Containerfile" "$PROFILE_DIR/Containerfile"
  echo "Reset $PROFILE_DIR/Containerfile from default"
  exit 0
fi

# ── Management: --args ─────────────────────────────────────────────────────

if [[ "$OPT_SET_ARGS_GIVEN" == true ]]; then
  PROFILE_NAME="$(profile_for_management)"
  PROFILE_DIR="$CLAUSE_DIR/profiles/$PROFILE_NAME"
  if [[ ! -d "$PROFILE_DIR" ]]; then
    echo "Error: profile '$PROFILE_NAME' does not exist. Create it with: clause $PROFILE_NAME --create-profile" >&2; exit 1
  fi
  echo "$OPT_SET_ARGS" > "$PROFILE_DIR/args.env"
  echo "Wrote $PROFILE_DIR/args.env: $OPT_SET_ARGS"
  exit 0
fi

# ── Management: --suggest-updates ──────────────────────────────────────────

# Print non-flag tokens that appear after the keyword in the given array.
# Usage: pkgs_after <keyword> <token...>
pkgs_after() {
  local keyword="$1"; shift
  local found=false tok
  for tok in "$@"; do
    if [[ "$found" == true && "$tok" != -* ]]; then
      echo "$tok"
    elif [[ "$tok" == "$keyword" ]]; then
      found=true
    fi
  done
}

# Render a RUN block for the given installer if its file has entries.
# Usage: render_block <file> <header> <footer>
render_block() {
  local file="$1" header="$2" footer="$3"
  [[ ! -s "$file" ]] && return 1
  local pkgs
  mapfile -t pkgs < <(sort -u "$file")
  echo "$header"
  local n=${#pkgs[@]} i
  for (( i=0; i<n-1; i++ )); do
    printf '    %s \\\n' "${pkgs[i]}"
  done
  printf '    %s' "${pkgs[n-1]}"
  if [[ -n "$footer" ]]; then
    printf ' \\\n%s\n' "$footer"
  else
    echo
  fi
  echo
  return 0
}

if [[ "$OPT_SUGGEST_UPDATES" == true ]]; then
  PROFILE_NAME="$(profile_for_management)"
  PROFILE_DIR="$CLAUSE_DIR/profiles/$PROFILE_NAME"
  if [[ ! -d "$PROFILE_DIR" ]]; then
    echo "Error: profile '$PROFILE_NAME' does not exist" >&2; exit 1
  fi
  LOG="$PROFILE_DIR/.claude/clause-sudo.log"
  if [[ ! -f "$LOG" ]]; then
    echo "No sudo log found at $LOG"; exit 0
  fi

  if [[ -f "$PROFILE_DIR/Containerfile" ]]; then
    TARGET="$PROFILE_DIR/Containerfile"
    TARGET_NOTE="profile Containerfile: $TARGET"
  else
    TARGET="$SCRIPT_DIR/defaults/Containerfile"
    TARGET_NOTE="default Containerfile (profile has no Containerfile; reset with: clause $PROFILE_NAME --reset-containerfile)"
  fi

  TMP=$(mktemp -d)
  trap 'rm -rf "$TMP"' EXIT

  # Extract every COMMAND= payload from the sudo log
  # Sudo wraps long log lines at column 80 with 4-space-indented continuations;
  # join them back together before extracting the COMMAND= payload.
  sed ':a;N;$!ba;s/\n[[:space:]]\+/ /g' "$LOG" | awk -F' ; COMMAND=' 'NF>1 {print $2}' | while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    read -ra T <<< "$line"
    cmd="${T[0]##*/}"
    case "$cmd" in
      apt|apt-get)
        pkgs_after install "${T[@]:1}" >> "$TMP/apt"
        ;;
      npm)
        # only -g / --global installs
        if printf '%s\n' "${T[@]:1}" | grep -qxE -- '-g|--global'; then
          pkgs_after install "${T[@]:1}" >> "$TMP/npm"
          pkgs_after i       "${T[@]:1}" >> "$TMP/npm"
        fi
        ;;
      pip|pip3)
        # skip --user installs (those go to ~/.local, not the image)
        if ! printf '%s\n' "${T[@]:1}" | grep -qx -- '--user'; then
          pkgs_after install "${T[@]:1}" >> "$TMP/pip"
        fi
        ;;
      gem)   pkgs_after install "${T[@]:1}" >> "$TMP/gem" ;;
      cargo) pkgs_after install "${T[@]:1}" >> "$TMP/cargo" ;;
      snap)  pkgs_after install "${T[@]:1}" >> "$TMP/snap" ;;
    esac
  done

  # Filter out packages already named in the target Containerfile (substring match)
  for f in "$TMP"/*; do
    [[ -f "$f" ]] || continue
    grep -vFf <(grep -oE '[a-zA-Z0-9_.+@/-]+' "$TARGET" | sort -u) "$f" > "$f.new" || true
    mv "$f.new" "$f"
  done

  echo "# Containerfile suggestions for profile '$PROFILE_NAME'"
  echo "# Source log: $LOG"
  echo "# Target:     $TARGET_NOTE"
  echo

  any=false
  render_block "$TMP/apt" \
    "RUN apt-get update && apt-get install -y \\" \
    "    && rm -rf /var/lib/apt/lists/*" && any=true
  render_block "$TMP/npm"   "RUN npm install -g \\"    "" && any=true
  render_block "$TMP/pip"   "RUN pip install --no-cache-dir \\" "" && any=true
  render_block "$TMP/gem"   "RUN gem install \\"       "" && any=true
  render_block "$TMP/cargo" "RUN cargo install \\"     "" && any=true
  render_block "$TMP/snap"  "RUN snap install \\"      "" && any=true

  if [[ "$any" == false ]]; then
    echo "# No new installs detected (log empty or all packages already present in target)."
  else
    echo "# To apply: append the relevant blocks to $TARGET, then: clause $PROFILE_NAME -b"
  fi
  exit 0
fi

# ── Management: --alias-create ─────────────────────────────────────────────

ALIAS_LINE="alias clause='$SCRIPT_DIR/clause' # clause-alias"

if [[ "$OPT_CREATE_ALIAS" == true ]]; then
  ALIAS_ADDED=false
  for RC in "$HOME/.bashrc" "$HOME/.zshrc"; do
    if [[ ! -f "$RC" ]]; then
      echo "Skipping $RC (not found)"
      continue
    fi
    if grep -qF '# clause-alias' "$RC"; then
      echo "Alias already exists in $RC"
      continue
    fi
    prompt_ynq "Add clause alias to $RC?"
    [[ "$PROMPT_REPLY" =~ ^[yY]$ ]] || continue
    echo "" >> "$RC"
    echo "$ALIAS_LINE" >> "$RC"
    echo "Added alias to $RC"
    ALIAS_ADDED=true
  done
  [[ "$ALIAS_ADDED" == false ]] && echo "No alias added."
  exit 0
fi

# ── Management: --alias-delete ─────────────────────────────────────────────

if [[ "$OPT_DELETE_ALIAS" == true ]]; then
  [[ "$OPT_N" == true ]] && { echo "Aborted."; exit 0; }
  for RC in "$HOME/.bashrc" "$HOME/.zshrc"; do
    [[ ! -f "$RC" ]] && continue
    if ! grep -qF '# clause-alias' "$RC"; then
      echo "No alias found in $RC"
      continue
    fi
    confirm_yes "Remove clause alias from $RC?" || { echo "Aborted."; continue; }
    sed -i '/# clause-alias$/d' "$RC"
    echo "Removed alias from $RC"
  done
  exit 0
fi

# ── Management: --runtime-set ──────────────────────────────────────────────

if [[ -n "$OPT_SET_RUNTIME" ]]; then
  if [[ "$OPT_SET_RUNTIME" != "podman" && "$OPT_SET_RUNTIME" != "docker" ]]; then
    echo "Error: invalid runtime '$OPT_SET_RUNTIME'. Must be 'podman' or 'docker'" >&2; exit 1
  fi
  if ! command -v "$OPT_SET_RUNTIME" &>/dev/null; then
    echo "Error: '$OPT_SET_RUNTIME' not found on PATH" >&2; exit 1
  fi
  if [[ -f "$RUNTIME_FILE" ]]; then
    EXISTING_RUNTIME="$(tr -d '[:space:]' < "$RUNTIME_FILE")"
    prompt_ynq "Runtime already set to '$EXISTING_RUNTIME'. Override with '$OPT_SET_RUNTIME'?"
    [[ "$PROMPT_REPLY" =~ ^[yY]$ ]] || { echo "Aborted."; exit 0; }
  fi
  echo "$OPT_SET_RUNTIME" > "$RUNTIME_FILE"
  echo "Runtime set to '$OPT_SET_RUNTIME' ($RUNTIME_FILE)"
  exit 0
fi

# ── Management: --runtime-remove ───────────────────────────────────────────

if [[ "$OPT_REMOVE_RUNTIME" == true ]]; then
  if [[ ! -f "$RUNTIME_FILE" ]]; then
    echo "Error: no runtime override is set" >&2; exit 1
  fi
  [[ "$OPT_N" == true ]] && { echo "Aborted."; exit 0; }
  confirm_yes "Remove runtime override?" || { echo "Aborted."; exit 0; }
  rm "$RUNTIME_FILE"
  echo "Runtime override removed. Auto-detection will be used."
  exit 0
fi

# ── Mapping management: -a / --add ─────────────────────────────────────────

if [[ "$OPT_A" == true ]]; then
  PROFILE_NAME="${OPT_PROFILE:-default}"
  if [[ ! -d "$CLAUSE_DIR/profiles/$PROFILE_NAME" ]]; then
    echo "Error: profile '$PROFILE_NAME' does not exist. Create it with: clause $PROFILE_NAME --create-profile" >&2; exit 1
  fi
  EXISTING="$(config_get "$WORKSPACE")"
  if [[ -n "$EXISTING" ]]; then
    echo "Warning: $WORKSPACE is already mapped to '$EXISTING'"
    prompt_ynq "Overwrite with '$PROFILE_NAME'?"
    case "$PROMPT_REPLY" in
      y|Y) ;;
      *) echo "Aborted."; exit 0 ;;
    esac
  fi
  config_set "$WORKSPACE" "$PROFILE_NAME"
  echo "Mapped $WORKSPACE → $PROFILE_NAME"
  exit 0
fi

# ── Mapping management: -r / --remove ──────────────────────────────────────

if [[ "$OPT_R" == true ]]; then
  SAVED="$(config_get "$WORKSPACE")"
  if [[ -z "$SAVED" ]]; then
    echo "Error: no mapping found for $WORKSPACE" >&2; exit 1
  fi
  prompt_ynq "Remove mapping $WORKSPACE → $SAVED?"
  case "$PROMPT_REPLY" in
    y|Y)
      config_del "$WORKSPACE"
      echo "Removed mapping: $WORKSPACE → $SAVED"
      ;;
    *)
      echo "Aborted."
      ;;
  esac
  exit 0
fi

# ── Resolve profile ─────────────────────────────────────────────────────────

REQUESTED="${OPT_PROFILE:-default}"
SAVED="$(config_get "$WORKSPACE")"
PROMPT_REPLY=""

if [[ -n "$SAVED" && -z "$OPT_PROFILE" ]]; then
  PROFILE="$SAVED"
elif [[ -z "$SAVED" || "$SAVED" != "$REQUESTED" ]]; then
  if [[ -z "$SAVED" ]]; then
    MSG="No mapping found. Save $WORKSPACE → $REQUESTED?"
  else
    MSG="Workspace mapped to '$SAVED'. Override with '$REQUESTED'?"
  fi
  prompt_ynq "$MSG"
  case "$PROMPT_REPLY" in
    y|Y)
      config_set "$WORKSPACE" "$REQUESTED"
      PROFILE="$REQUESTED"
      ;;
    n|N)
      PROFILE="${SAVED:-$REQUESTED}"
      ;;
    *)
      echo "Aborted."; exit 0
      ;;
  esac
else
  PROFILE="$SAVED"
fi

# ── Verify profile exists ───────────────────────────────────────────────────

PROFILE_DIR="$CLAUSE_DIR/profiles/$PROFILE"
if [[ ! -d "$PROFILE_DIR" ]]; then
  echo "Error: profile '$PROFILE' does not exist. Create it with: clause $PROFILE --create-profile" >&2
  exit 1
fi

# ── Init profile runtime data ───────────────────────────────────────────────

mkdir -p "$PROFILE_DIR/.claude"
[[ ! -f "$PROFILE_DIR/.claude.json" ]] && echo '{}' > "$PROFILE_DIR/.claude.json"
touch "$PROFILE_DIR/.gitconfig"
touch "$PROFILE_DIR/.claude/clause-sudo.log"

[[ ! -f "$PROFILE_DIR/.claude/settings.json" ]] && cp "$SCRIPT_DIR/defaults/settings.json" "$PROFILE_DIR/.claude/settings.json"
[[ ! -f "$PROFILE_DIR/.claude/CLAUDE.md" ]] && cp "$SCRIPT_DIR/defaults/CLAUDE.md" "$PROFILE_DIR/.claude/CLAUDE.md"
[[ ! -f "$PROFILE_DIR/args.env" ]] && cp "$SCRIPT_DIR/defaults/args.env" "$PROFILE_DIR/args.env"

# ── Resolve image name ──────────────────────────────────────────────────────

if [[ -f "$PROFILE_DIR/Containerfile" ]]; then
  IMAGE_NAME="clause-$PROFILE"
else
  IMAGE_NAME="clause"
fi

# ── Ensure image exists ─────────────────────────────────────────────────────

if ! image_exists "$IMAGE_NAME"; then
  echo "Error: '$IMAGE_NAME' image not found. Build it with: clause --build" >&2
  exit 1
fi

# ── Resolve container command ───────────────────────────────────────────────

# TODO: remove this migration once users have had time to migrate
[[ -f "$WORKSPACE/.last-session-id" ]] && mv "$WORKSPACE/.last-session-id" "$WORKSPACE/.clause-session-id"

if [[ "$OPT_T" == true ]]; then
  CONTAINER_CMD=(bash)
else
  SESSION_ID="$(session_get)"
  if [[ -n "$SESSION_ID" ]]; then
    if [[ ! -d "$PROFILE_DIR/.claude/session-env/$SESSION_ID" ]]; then
      session_del
      prompt_ynq "Warning: saved session '$SESSION_ID' not found in profile. Start a new session?"
      case "$PROMPT_REPLY" in
        y|Y) CONTAINER_CMD=(claude) ;;
        *) echo "Aborted."; exit 0 ;;
      esac
    else
      session_del
      CONTAINER_CMD=(claude --resume "$SESSION_ID")
    fi
  else
    CONTAINER_CMD=(claude)
  fi

  if [[ -s "$PROFILE_DIR/args.env" ]]; then
    read -r ARGS_LINE < "$PROFILE_DIR/args.env" || true
    if [[ -n "$ARGS_LINE" ]]; then
      # shellcheck disable=SC2206
      ARGS_ARRAY=($ARGS_LINE)
      CONTAINER_CMD+=("${ARGS_ARRAY[@]}")
    fi
  fi
fi

# ── Launch container ────────────────────────────────────────────────────────

CONTAINER_NAME="clause-$$"

cleanup() {
  "$CONTAINER_CLI" stop "$CONTAINER_NAME" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

USER_FLAGS=()
if [[ "$CONTAINER_CLI" == "podman" ]]; then
  USER_FLAGS+=(--userns=keep-id:uid=1000,gid=1000)
else
  USER_FLAGS+=(--user "$(id -u):$(id -g)")
fi

"$CONTAINER_CLI" run --rm -it --name "$CONTAINER_NAME" \
  "${USER_FLAGS[@]}" \
  -v "$PROFILE_DIR/.claude:/home/claude/.claude" \
  -v "$PROFILE_DIR/.claude.json:/home/claude/.claude.json" \
  -v "$PROFILE_DIR/.gitconfig:/home/claude/.gitconfig" \
  -v "$WORKSPACE:/workspace" \
  -e "TERM=xterm-256color" \
  -w /workspace \
  "$IMAGE_NAME" \
  "${CONTAINER_CMD[@]}"
