#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
TARGET="${1:-$PWD}"

if [[ ! -d "$TARGET" ]]; then
  echo "error: '$TARGET' is not a directory" >&2
  exit 1
fi

TARGET="$(realpath "$TARGET")"

mkdir -p "$SCRIPT_DIR/.claude"
touch "$SCRIPT_DIR/.claude.json"

CONTAINER_NAME="clause-$$"

cleanup() {
  podman stop "$CONTAINER_NAME" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

podman run --rm -it --name "$CONTAINER_NAME" \
  -v "$SCRIPT_DIR/.claude:/root/.claude" \
  -v "$SCRIPT_DIR/.claude.json:/root/.claude.json" \
  -v "$TARGET:/workspace" \
  -w /workspace \
  clause
