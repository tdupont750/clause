#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLAUSE_DIR="$HOME/.clause"
PROFILES_DIR="$CLAUSE_DIR/profiles"
CONF_FILE="$CLAUSE_DIR/clause.conf"
RUNTIME_FILE="$CLAUSE_DIR/runtime"

usage() {
  cat <<'EOF'
usage: clause [-h] [profile] [options]

arguments:
  profile                 Profile to use (default: 'default')

session options:
  -a, --args <value>      One-shot claude args (overrides clause-args files)
  -e, --effort <level>    One-shot effort override: low|medium|high|xhigh|max
  -t, --terminal          Launch bash instead of claude
  -w, --workspace <path>  Workspace directory (default: $PWD)

prompt options:
  -y, --yes               Auto-answer yes to prompts (destructive
                          confirmations still require typing 'yes')
  -n, --no                Auto-answer no to all prompts

mapping (then exit):
  -m, --map               Add workspace→profile mapping
  -u, --unmap             Remove workspace→profile mapping
  -l, --list              Show current mapping and list all profiles
  -L, --list-all          List all workspace→profile mappings

profile management (then exit):
  -C, --create-profile        Create a new profile (Containerfile + clause-args seeded)
  -D, --delete-profile        Delete a profile and remove its mappings
  -R, --reset-containerfile   Overwrite profile Containerfile with default
  -S, --suggest-updates       Suggest Containerfile updates from sudo log

arguments (then exit):
  -A, --args-view                 Print effective claude args + source
      --args-set <value>          Write workspace .clause-args (this directory)
      --args-set-profile <value>  Write profile clause-args
                                  Default: --effort max --dangerously-skip-permissions

effort override (then exit):
  --effort-set <level>            Write workspace .clause-effort (this directory)
  --effort-set-profile <level>    Write profile effort file
  --effort-remove                 Remove workspace .clause-effort
  --effort-remove-profile         Remove profile effort file
                                  Levels: low|medium|high|xhigh|max

nested podman (then exit):
  -P, --podman-enable     Enable nested podman for profile (marker + Containerfile block)
      --podman-disable    Disable nested podman for profile
      --podman-reset      Remove the profile's nested-podman storage volume

alias management (then exit):
  --alias-create          Add clause alias to .bashrc and/or .zshrc
  --alias-delete          Remove clause alias from .bashrc and/or .zshrc

runtime management (then exit):
  --runtime-set <value>   Set container runtime override (podman or docker)
  --runtime-remove        Remove container runtime override

other:
  -b, --build             Build the container image
  -h, --help              Print this help
EOF
}

# ── Argument parsing ────────────────────────────────────────────────────────

# All OPT_*/COMMAND state is script-global on purpose: parse_args assigns
# these without `local`, and helpers plus cmd_* functions read them directly.

# Modifiers: combine freely with any command.
OPT_ARGS=""
OPT_ARGS_GIVEN=false
OPT_EFFORT=""
OPT_EFFORT_GIVEN=false
OPT_YES=false
OPT_NO=false
OPT_TERMINAL=false
OPT_PROFILE=""
OPT_WORKSPACE=""

# Command values: only meaningful when the matching command is selected.
OPT_ARGS_SET=""
OPT_ARGS_SET_PROFILE=""
OPT_EFFORT_SET=""
OPT_EFFORT_SET_PROFILE=""
OPT_RUNTIME_SET=""

# One command per invocation: the first command flag claims COMMAND (default:
# launch) and any second one is a hard error, raised at parse time before
# anything runs.
COMMAND="launch"
COMMAND_FLAG=""
set_command() {
  if [[ "$COMMAND" != "launch" ]]; then
    echo "Error: $1 conflicts with $COMMAND_FLAG" >&2; exit 1
  fi
  COMMAND="$2"
  COMMAND_FLAG="$1"
}

# Parse CLI args into the OPT_*/COMMAND globals. Must be called as
# `parse_args "$@"`: $# and shift inside a function operate on the function's
# own arguments, not the script's. `exit` in the branches below (-h, parse
# errors) ends the whole script, not just this function, so nothing after a
# parse error or -h can run.
parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      # session options
      -a|--args)
        [[ $# -lt 2 ]] && { echo "Error: $1 requires a string value" >&2; exit 1; }
        OPT_ARGS="$2"
        OPT_ARGS_GIVEN=true
        shift 2
        ;;
      -e|--effort)
        [[ $# -lt 2 ]] && { echo "Error: $1 requires a level" >&2; exit 1; }
        validate_effort "$2" || exit 1
        OPT_EFFORT="$2"
        OPT_EFFORT_GIVEN=true
        shift 2
        ;;
      -t|--terminal) OPT_TERMINAL=true; shift ;;
      -w|--workspace)
        [[ $# -lt 2 ]] && { echo "Error: $1 requires a path" >&2; exit 1; }
        OPT_WORKSPACE="$2"
        shift 2
        ;;

      # prompt options
      -y|--yes) OPT_YES=true; shift ;;
      -n|--no) OPT_NO=true; shift ;;

      # mapping (then exit)
      -m|--map) set_command "$1" map; shift ;;
      -u|--unmap) set_command "$1" unmap; shift ;;
      -l|--list) set_command "$1" list; shift ;;
      -L|--list-all) set_command "$1" list-all; shift ;;

      # profile management (then exit)
      -C|--create-profile) set_command "$1" create-profile; shift ;;
      -D|--delete-profile) set_command "$1" delete-profile; shift ;;
      -R|--reset-containerfile) set_command "$1" reset-containerfile; shift ;;
      -S|--suggest-updates) set_command "$1" suggest-updates; shift ;;

      # arguments (then exit)
      -A|--args-view) set_command "$1" args-view; shift ;;
      --args-set)
        [[ $# -lt 2 ]] && { echo "Error: $1 requires a string value" >&2; exit 1; }
        set_command "$1" args-set
        OPT_ARGS_SET="$2"
        shift 2
        ;;
      --args-set-profile)
        [[ $# -lt 2 ]] && { echo "Error: $1 requires a string value" >&2; exit 1; }
        set_command "$1" args-set-profile
        OPT_ARGS_SET_PROFILE="$2"
        shift 2
        ;;

      # effort override (then exit)
      --effort-set)
        [[ $# -lt 2 ]] && { echo "Error: $1 requires a level" >&2; exit 1; }
        validate_effort "$2" || exit 1
        set_command "$1" effort-set
        OPT_EFFORT_SET="$2"
        shift 2
        ;;
      --effort-set-profile)
        [[ $# -lt 2 ]] && { echo "Error: $1 requires a level" >&2; exit 1; }
        validate_effort "$2" || exit 1
        set_command "$1" effort-set-profile
        OPT_EFFORT_SET_PROFILE="$2"
        shift 2
        ;;
      --effort-remove) set_command "$1" effort-remove; shift ;;
      --effort-remove-profile) set_command "$1" effort-remove-profile; shift ;;

      # nested podman (then exit)
      -P|--podman-enable) set_command "$1" podman-enable; shift ;;
      --podman-disable) set_command "$1" podman-disable; shift ;;
      --podman-reset) set_command "$1" podman-reset; shift ;;

      # alias management (then exit)
      --alias-create) set_command "$1" alias-create; shift ;;
      --alias-delete) set_command "$1" alias-delete; shift ;;

      # runtime management (then exit)
      --runtime-set)
        [[ $# -lt 2 ]] && { echo "Error: --runtime-set requires a value (podman or docker)" >&2; exit 1; }
        set_command "$1" runtime-set
        OPT_RUNTIME_SET="$2"
        shift 2
        ;;
      --runtime-remove) set_command "$1" runtime-remove; shift ;;

      # other
      -b|--build) set_command "$1" build; shift ;;
      -h|--help) usage; exit 0 ;;

      # fallthrough
      -*)
        echo "Error: unknown option '$1'" >&2; usage >&2; exit 1
        ;;
      *)
        if [[ -n "$OPT_PROFILE" ]]; then
          echo "Error: unexpected argument '$1'" >&2; usage >&2; exit 1
        fi
        OPT_PROFILE="${1,,}"
        shift
        ;;
    esac
  done

  # Command-vs-command conflicts are handled by set_command during parsing;
  # -y/-n are modifiers, so their conflict is checked after the full line is
  # parsed.
  if [[ "$OPT_YES" == true && "$OPT_NO" == true ]]; then
    echo "Error: -y and -n are mutually exclusive" >&2; exit 1
  fi
}

# ── Startup steps (main calls these in order before dispatching) ────────────

# Sets WORKSPACE: the validated absolute form of -w/--workspace, else $PWD.
resolve_workspace() {
  if [[ -n "$OPT_WORKSPACE" ]]; then
    if [[ ! -d "$OPT_WORKSPACE" ]]; then
      echo "Error: workspace '$OPT_WORKSPACE' is not a directory" >&2; exit 1
    fi
    WORKSPACE="$(realpath "$OPT_WORKSPACE")"
  else
    WORKSPACE="$(realpath "$PWD")"
  fi
}

# Create the ~/.clause layout idempotently. The guard keeps the documented
# promise that the pure read-only commands (-l / -L / -A) never touch disk;
# -h never reaches this point (parse_args exits). init_profile_runtime is
# defined further down the file: safe, because no function body runs until
# `main "$@"` on the last line, after every definition has been parsed.
bootstrap_state() {
  case "$COMMAND" in
    list|list-all|args-view) return 0 ;;
  esac
  init_profile_runtime "$PROFILES_DIR/default"
  touch "$CONF_FILE"
}

# Sets CONTAINER_CLI. Only commands that shell out to it get past the guard.
# Everything else (including runtime-set, which manages the very setting that
# drives detection) must not error on a runtime-less system.
detect_runtime() {
  case "$COMMAND" in
    build|delete-profile|podman-reset|launch) ;;
    *) return 0 ;;
  esac
  if [[ -f "$RUNTIME_FILE" ]]; then
    CONTAINER_CLI="$(tr -d '[:space:]' < "$RUNTIME_FILE")"
    if [[ -z "$CONTAINER_CLI" ]]; then
      echo "Error: $RUNTIME_FILE is empty; remove it or run: clause --runtime-set podman" >&2; exit 1
    fi
    if [[ "$CONTAINER_CLI" != "podman" && "$CONTAINER_CLI" != "docker" ]]; then
      echo "Error: invalid runtime '$CONTAINER_CLI' in $RUNTIME_FILE. Must be 'podman' or 'docker'" >&2; exit 1
    fi
    if ! command -v "$CONTAINER_CLI" &>/dev/null; then
      echo "Error: runtime '$CONTAINER_CLI' set in $RUNTIME_FILE but not found on PATH" >&2; exit 1
    fi
  elif command -v podman &>/dev/null; then
    CONTAINER_CLI="podman"
  elif command -v docker &>/dev/null; then
    CONTAINER_CLI="docker"
  else
    echo "Error: neither podman nor docker found on PATH" >&2; exit 1
  fi
}

# ── Config helpers ──────────────────────────────────────────────────────────

config_get() {
  local workspace="$1"
  [[ -f "$CONF_FILE" ]] || return 0
  awk -F= -v ws="$workspace" '$1 == ws { print $2; exit }' "$CONF_FILE"
}

config_set() {
  local workspace="$1" profile="$2"
  config_del "$workspace"
  echo "${workspace}=${profile}" >> "$CONF_FILE"
}

config_del() {
  local workspace="$1"
  [[ ! -f "$CONF_FILE" ]] && return
  awk -F= -v ws="$workspace" '$1 != ws' "$CONF_FILE" > "${CONF_FILE}.tmp"
  mv "${CONF_FILE}.tmp" "$CONF_FILE"
}

config_del_by_profile() {
  local profile="$1"
  [[ ! -f "$CONF_FILE" ]] && echo "0" && return
  local count
  count=$(awk -F= -v p="$profile" '$2 == p { c++ } END { print c+0 }' "$CONF_FILE")
  awk -F= -v p="$profile" '$2 != p' "$CONF_FILE" > "${CONF_FILE}.tmp"
  mv "${CONF_FILE}.tmp" "$CONF_FILE"
  echo "$count"
}

# ── Container helpers ───────────────────────────────────────────────────────

image_exists() {
  "$CONTAINER_CLI" image inspect "$1" &>/dev/null
}

volume_exists() {
  "$CONTAINER_CLI" volume inspect "$1" &>/dev/null
}

# ── Prompt helpers ──────────────────────────────────────────────────────────

# Sets global PROMPT_REPLY to y, n, or q
prompt_ynq() {
  local message="$1"
  if [[ "$OPT_YES" == true ]]; then
    echo "${message} [y/n/q] y"
    PROMPT_REPLY="y"
    return
  fi
  if [[ "$OPT_NO" == true ]]; then
    echo "${message} [y/n/q] n"
    PROMPT_REPLY="n"
    return
  fi
  read -r -n 1 -p "${message} [y/n/q] " PROMPT_REPLY
  echo
}

# prompt_ynq wrapper: true only on an explicit yes
prompt_yes() {
  prompt_ynq "$1"
  [[ "$PROMPT_REPLY" =~ ^[yY]$ ]]
}

# Prompts for literal "yes"; returns 1 (false) if not confirmed.
# -n auto-declines; -y deliberately does not auto-confirm destructive actions.
confirm_yes() {
  local message="$1"
  local reply
  [[ "$OPT_NO" == true ]] && return 1
  read -r -p "${message} Type 'yes' to confirm: " reply
  [[ "$reply" == "yes" ]]
}

# ── Profile resolution helper (silent, for management commands) ─────────────

profile_for_management() {
  local saved
  saved="$(config_get "$WORKSPACE")"
  echo "${OPT_PROFILE:-${saved:-default}}"
}

# Resolve PROFILE_NAME ($1 if given, else positional > mapping > default) and
# PROFILE_DIR; error out if the profile directory does not exist.
require_profile() {
  PROFILE_NAME="${1:-$(profile_for_management)}"
  PROFILE_DIR="$PROFILES_DIR/$PROFILE_NAME"
  if [[ ! -d "$PROFILE_DIR" ]]; then
    echo "Error: profile '$PROFILE_NAME' does not exist. Create it with: clause $PROFILE_NAME --create-profile" >&2
    exit 1
  fi
}

# ── Claude args resolution helper ───────────────────────────────────────────

# Resolve the args appended to claude: -a/--args one-shot > workspace
# .clause-args (present file wins, even empty) > profile clause-args (same).
# Sets ARGS_LINE (first line of the winning source) and ARGS_SOURCE; an empty
# ARGS_SOURCE means no source was found. Uses globals WORKSPACE, PROFILE_DIR.
resolve_args() {
  ARGS_LINE=""
  ARGS_SOURCE=""
  if [[ "$OPT_ARGS_GIVEN" == true ]]; then
    ARGS_LINE="$OPT_ARGS"
    ARGS_SOURCE="-a/--args"
  elif [[ -f "$WORKSPACE/.clause-args" ]]; then
    read -r ARGS_LINE < "$WORKSPACE/.clause-args" || true
    ARGS_SOURCE="$WORKSPACE/.clause-args"
  elif [[ -f "$PROFILE_DIR/clause-args" ]]; then
    read -r ARGS_LINE < "$PROFILE_DIR/clause-args" || true
    ARGS_SOURCE="$PROFILE_DIR/clause-args"
  fi
}

# ── Effort override resolution helpers ──────────────────────────────────────

# Valid levels for the claude --effort flag. Includes `max`, which settings.json's
# effortLevel does not accept: we drive the CLI flag (what clause-args ships), not
# the setting. Returns nonzero with a message on an invalid level.
validate_effort() {
  case "$1" in
    low|medium|high|xhigh|max) return 0 ;;
    *) echo "Error: invalid effort '$1'. Must be one of: low, medium, high, xhigh, max" >&2; return 1 ;;
  esac
}

# Resolve the effort override, parallel to resolve_args: -e/--effort one-shot >
# workspace .clause-effort > profile effort file. A one-shot -a bypasses the args
# files, so it also bypasses the stored effort files (only -e refines -a). Empty
# or whitespace files mean "unset" and fall through; a syntactically invalid file
# value is warned about and skipped, so a hand-edited file cannot break launch.
# Sets EFFORT_VALUE and EFFORT_SOURCE (empty EFFORT_SOURCE means no override).
# Uses globals WORKSPACE, PROFILE_DIR.
resolve_effort() {
  EFFORT_VALUE=""
  EFFORT_SOURCE=""
  if [[ "$OPT_EFFORT_GIVEN" == true ]]; then
    EFFORT_VALUE="$OPT_EFFORT"
    EFFORT_SOURCE="-e/--effort"
    return
  fi
  # -a is a complete one-shot args override; respect it verbatim.
  [[ "$OPT_ARGS_GIVEN" == true ]] && return
  local val src
  for src in "$WORKSPACE/.clause-effort" "$PROFILE_DIR/effort"; do
    [[ -f "$src" ]] || continue
    read -r val < "$src" || true
    val="${val//[[:space:]]/}"
    [[ -z "$val" ]] && continue
    if ! validate_effort "$val" 2>/dev/null; then
      echo "Warning: ignoring invalid effort '$val' in $src" >&2
      continue
    fi
    EFFORT_VALUE="$val"
    EFFORT_SOURCE="$src"
    return
  done
}

# Inject EFFORT_VALUE into ARGS_LINE: replace an existing --effort / --effort=
# token, else append. Guarantees exactly one --effort in the final command; no-op
# when EFFORT_VALUE is empty. Rebuilds ARGS_LINE from tokens (downstream re-splits
# with read -ra, so collapsed spacing does not matter).
apply_effort_to_args() {
  [[ -z "$EFFORT_VALUE" ]] && return
  local -a toks out=()
  read -ra toks <<< "$ARGS_LINE" || true
  local i replaced=false
  for (( i=0; i<${#toks[@]}; i++ )); do
    case "${toks[i]}" in
      --effort)
        out+=(--effort "$EFFORT_VALUE")
        replaced=true
        i=$((i+1))  # skip old value; `((i++))` returns 1 at i=0 and trips set -e
        ;;
      --effort=*)
        out+=("--effort=$EFFORT_VALUE")
        replaced=true
        ;;
      *)
        out+=("${toks[i]}")
        ;;
    esac
  done
  [[ "$replaced" == false ]] && out+=(--effort "$EFFORT_VALUE")
  ARGS_LINE="${out[*]}"
}

# ── Profile runtime scaffold helper ─────────────────────────────────────────

# Create a profile's empty runtime files (idempotent, never overwrites).
init_profile_runtime() {
  local profile_dir="$1"
  mkdir -p "$profile_dir/.claude"
  [[ ! -f "$profile_dir/.claude.json" ]] && echo '{}' > "$profile_dir/.claude.json"
  touch "$profile_dir/.gitconfig" "$profile_dir/.claude/clause-sudo.log"
}

# ── Profile seeding helper ──────────────────────────────────────────────────

# default/ mirrors a profile's layout: default/<rel> seeds to <profile>/<rel>.
# Seeds only missing files (never overwrites); cp -p carries the +x bit on hooks.
# find walks dotpaths correctly (a `cp default/*` glob would skip .claude/).
# $1 = profile dir; $2 = "verbose" to echo each seeded path.
seed_profile() {
  local profile_dir="$1" verbose="${2:-}" src rel dest
  while IFS= read -r src; do
    rel="${src#"$SCRIPT_DIR/default/"}"
    dest="$profile_dir/$rel"
    [[ -f "$dest" ]] && continue
    mkdir -p "$(dirname "$dest")"
    cp -p "$src" "$dest"
    [[ "$verbose" == verbose ]] && echo "Seeded $dest"
  done < <(find "$SCRIPT_DIR/default" -type f | sort)
  # return 0 is load-bearing under set -e: in non-verbose mode the loop's
  # trailing `[[ verbose ]] && echo` leaves status 1, which would otherwise
  # kill the script at any bare seed_profile call
  return 0
}

# ── Nested podman helpers ───────────────────────────────────────────────────

# The Containerfile block managed by --podman-enable / --podman-disable.
# Everything between the begin/end markers is owned by clause; --podman-disable
# deletes exactly that range. subuid/subgid 1:999 + 1001:64535 is the standard
# podman-in-podman layout for a uid-1000 user: it skips 1000 (already the
# user's own uid) and fits inside the ~65k uids the outer userns provides.
nested_containerfile_block() {
  cat <<'EOF'
# clause-nested-begin
USER root
RUN apt-get update && apt-get install -y \
    podman \
    uidmap \
    slirp4netns \
    fuse-overlayfs \
    podman-compose \
    && rm -rf /var/lib/apt/lists/* \
    && printf 'claude:1:999\nclaude:1001:64535\n' > /etc/subuid \
    && printf 'claude:1:999\nclaude:1001:64535\n' > /etc/subgid \
    && printf 'unqualified-search-registries = ["docker.io"]\n' > /etc/containers/registries.conf \
    && printf '[engine]\ncgroup_manager = "cgroupfs"\nevents_logger = "file"\n' >> /etc/containers/containers.conf
RUN arch="$(dpkg --print-architecture)" \
    && case "$arch" in amd64) larch=x86_64 ;; arm64) larch=arm64 ;; *) echo "unsupported arch: $arch" >&2; exit 1 ;; esac \
    && tag="$(curl -fsSLo /dev/null -w '%{url_effective}' https://github.com/jesseduffield/lazydocker/releases/latest)" \
    && tag="${tag##*/}" \
    && curl -fsSL "https://github.com/jesseduffield/lazydocker/releases/download/${tag}/lazydocker_${tag#v}_Linux_${larch}.tar.gz" \
       | tar -xz -C /usr/local/bin lazydocker
USER claude
RUN mkdir -p /home/claude/.local/share/containers
# lazydocker speaks the docker API; compose actions are mapped to podman-compose
RUN mkdir -p /home/claude/.config/lazydocker \
    && printf 'commandTemplates:\n  dockerCompose: podman-compose\n' > /home/claude/.config/lazydocker/config.yml
# lazydocker wrapper: start podman's API socket on demand, point DOCKER_HOST at it
# (alias ld shadows the binutils linker in interactive shells only)
RUN printf '%s\n' \
    '' \
    'lazydocker() {' \
    '  local sock' \
    '  sock="$(podman info --format "{{.Host.RemoteSocket.Path}}" 2>/dev/null)"' \
    '  sock="${sock#unix://}"' \
    '  if [ -z "$sock" ]; then' \
    '    echo "lazydocker: podman not available; nested podman must be enabled" >&2' \
    '    return 1' \
    '  fi' \
    '  if [ ! -S "$sock" ]; then' \
    '    (podman system service --time=0 >/dev/null 2>&1 &)' \
    '    local i=0' \
    '    while [ "$i" -lt 50 ] && [ ! -S "$sock" ]; do sleep 0.1; i=$((i+1)); done' \
    '  fi' \
    '  DOCKER_HOST="unix://$sock" command lazydocker "$@"' \
    '}' \
    "alias ld='lazydocker'" \
    >> /home/claude/.bashrc
# clause-nested-end
EOF
}

# ── Suggest-updates helpers ────────────────────────────────────────────────

# Print non-flag tokens that appear after the keyword in the given array.
# Usage: pkgs_after <keyword> <token...>
pkgs_after() {
  local keyword="$1"; shift
  local found=false tok
  for tok in "$@"; do
    if [[ "$found" == true && "$tok" != -* ]]; then
      echo "$tok"
    elif [[ "$tok" == "$keyword" ]]; then
      found=true
    fi
  done
}

# Render a RUN block for the given installer if its file has entries.
# Usage: render_block <file> <header> <footer>
render_block() {
  local file="$1" header="$2" footer="$3"
  [[ ! -s "$file" ]] && return 1
  local pkgs
  mapfile -t pkgs < <(sort -u "$file")
  echo "$header"
  local n=${#pkgs[@]} i
  for (( i=0; i<n-1; i++ )); do
    printf '    %s \\\n' "${pkgs[i]}"
  done
  printf '    %s' "${pkgs[n-1]}"
  if [[ -n "$footer" ]]; then
    printf ' \\\n%s\n' "$footer"
  else
    echo
  fi
  echo
  return 0
}

# ── Command: --build ─────────────────────────────────────────────────────────

cmd_build() {
  require_profile
  seed_profile "$PROFILE_DIR"
  "$CONTAINER_CLI" build --no-cache -t "clause-$PROFILE_NAME" "$PROFILE_DIR"
  exit 0
}

# ── Command: --create-profile ──────────────────────────────────────────────

cmd_create_profile() {
  PROFILE_NAME="$(profile_for_management)"
  PROFILE_DIR="$PROFILES_DIR/$PROFILE_NAME"
  if [[ -d "$PROFILE_DIR" ]]; then
    echo "Error: profile '$PROFILE_NAME' already exists" >&2; exit 1
  fi
  prompt_yes "Create profile '$PROFILE_NAME'?" || { echo "Aborted."; exit 0; }
  init_profile_runtime "$PROFILE_DIR"
  echo "Created profile '$PROFILE_NAME'"
  seed_profile "$PROFILE_DIR" verbose
  EXISTING="$(config_get "$WORKSPACE")"
  if [[ -n "$EXISTING" && "$EXISTING" != "$PROFILE_NAME" ]]; then
    echo "Warning: $WORKSPACE is already mapped to '$EXISTING'" >&2
    if prompt_yes "Overwrite with '$PROFILE_NAME'?"; then
      config_set "$WORKSPACE" "$PROFILE_NAME"
      echo "Mapped $WORKSPACE → $PROFILE_NAME"
    else
      echo "Kept existing mapping: $WORKSPACE → $EXISTING"
    fi
  else
    config_set "$WORKSPACE" "$PROFILE_NAME"
    echo "Mapped $WORKSPACE → $PROFILE_NAME"
  fi
  exit 0
}

# ── Command: --delete-profile ──────────────────────────────────────────────

cmd_delete_profile() {
  require_profile
  if [[ "$PROFILE_NAME" == "default" ]]; then
    echo "Error: cannot delete the default profile" >&2; exit 1
  fi
  confirm_yes "Delete profile '$PROFILE_NAME' and all its data?" || { echo "Aborted."; exit 0; }
  IMAGE_NAME="clause-$PROFILE_NAME"
  VOLUME_NAME="clause-$PROFILE_NAME-containers"
  rm -rf "$PROFILE_DIR"
  if image_exists "$IMAGE_NAME"; then
    "$CONTAINER_CLI" rmi "$IMAGE_NAME" >/dev/null 2>&1 || true
    echo "Removed image '$IMAGE_NAME'"
  fi
  if volume_exists "$VOLUME_NAME"; then
    "$CONTAINER_CLI" volume rm "$VOLUME_NAME" >/dev/null 2>&1 || true
    echo "Removed volume '$VOLUME_NAME'"
  fi
  COUNT=$(config_del_by_profile "$PROFILE_NAME")
  [[ "$COUNT" -gt 0 ]] && echo "Removed ${COUNT} mapping(s) for profile '$PROFILE_NAME'"
  echo "Deleted profile '$PROFILE_NAME'"
  exit 0
}

# ── Command: -l / --list ───────────────────────────────────────────────────

cmd_list() {
  CURRENT_MAPPING="$(config_get "$WORKSPACE")"
  if [[ -n "$CURRENT_MAPPING" ]]; then
    echo "$WORKSPACE → $CURRENT_MAPPING"
  else
    echo "$WORKSPACE → (no mapping)"
  fi
  echo
  echo "profiles:"
  shopt -s nullglob
  FOUND=false
  for d in "$PROFILES_DIR"/*/; do
    if [[ -f "$d/nested" ]]; then
      echo "  $(basename "$d") (nested)"
    else
      echo "  $(basename "$d")"
    fi
    FOUND=true
  done
  shopt -u nullglob
  [[ "$FOUND" == false ]] && echo "  (no profiles)"
  exit 0
}

