#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLAUSE_DIR="$HOME/.clause"
PROFILES_DIR="$CLAUSE_DIR/profiles"
RUNTIME_FILE="$CLAUSE_DIR/runtime"

usage() {
  cat <<'EOF'
usage: clause [session options]               launch Claude (default)
       clause <command> ...                    manage clause, then exit

With no command, clause launches the profile bound to this workspace (default:
'default'). Point a workspace at a profile with `clause bind [profile]`.

session options (shape the launch; combine with any command):
  -t, --terminal          Launch bash instead of claude
  -w, --workspace <path>  Workspace directory (default: $PWD)
  -a, --args <value>      One-shot claude args (overrides args files)
  -e, --effort <level>    One-shot effort override: low|medium|high|xhigh|max
  -y, --yes               Auto-answer yes to prompts (destructive
                          confirmations still require typing 'yes')
  -n, --no                Auto-answer no to all prompts

commands (then exit):
  config <key> [value]              Set a profile config key (args, effort)
  config --local <key> [value]      Set a workspace override (args, effort, mount)
  config --get <key>                Print one effective value (raw)
  config --reset <key>              Reset a profile key to its template default
  config --local --reset <key>      Remove a workspace override
  config --list                     Show workspace + profile config
  bind [profile]                    Bind this workspace to a profile (-p)
  bind --unset                      Remove this workspace's binding
  profile create [name]             Create a profile (seeded from default/)
  profile delete [name]             Delete a profile, its image and volume
  profile list                      List profiles
  image build                       Build the bound profile's image (-b)
  image suggest                     Print suggested Containerfile edits
  podman enable                     Enable nested podman for the profile
  podman disable                    Disable nested podman
  podman reset                      Reset the nested storage volume
  status                            Effective config for this directory

global (machine-wide setup):
  runtime <podman|docker>           Pin the container runtime
  runtime --unset                   Clear the runtime override
  alias create                      Install the clause shell alias
  alias delete                      Remove the shell alias

  -h, --help                        Print this help
EOF
}

# ── Argument parsing ────────────────────────────────────────────────────────

# All OPT_*/COMMAND state is script-global on purpose: parse_args assigns
# these without `local`, and helpers plus cmd_* functions read them directly.

# Modifiers: combine freely with any command.
OPT_ARGS=""
OPT_ARGS_GIVEN=false
OPT_EFFORT=""
OPT_EFFORT_GIVEN=false
OPT_YES=false
OPT_NO=false
OPT_TERMINAL=false
OPT_PROFILE=""
OPT_WORKSPACE=""

# Command values: only meaningful when the matching command is selected.
OPT_RUNTIME_SET=""

# config subcommand state (populated by parse_config_args when COMMAND=config).
OPT_CONFIG_SCOPE="profile"     # profile | workspace
OPT_CONFIG_ACTION=""           # set | get | reset | list
OPT_CONFIG_KEY=""
OPT_CONFIG_VALUE=""
OPT_CONFIG_VALUE_GIVEN=false

# Runtime globals: set by the startup steps, resolver helpers, and prompts,
# then read across functions. This block is the map of the cross-function data
# flow; state a single command body needs is `local` to that body instead.
WORKSPACE=""           # resolve_workspace
CONTAINER_CLI=""       # detect_runtime
PROFILE_NAME=""        # require_profile / profile_for_management callers
PROFILE_DIR=""         # require_profile / the silent resolvers
PROMPT_REPLY=""        # prompt_ynq
LAYERED_VALUE=""       # resolve_layered
LAYERED_SOURCE=""      # resolve_layered
ARGS_LINE=""           # resolve_args, rewritten by apply_effort_to_args
ARGS_SOURCE=""         # resolve_args
EFFORT_VALUE=""        # resolve_effort
EFFORT_SOURCE=""       # resolve_effort
MOUNT_VALUE=""         # resolve_mount_path
MOUNT_SOURCE=""        # resolve_mount_path
CONFIG_FILE_PATH=""    # config_file_for
PROBED_RUNTIME=""      # probe_runtime
PROBED_RUNTIME_SOURCE=""  # probe_runtime: file | detected | ""
CONTAINER_NAME=""      # cmd_launch; deliberately global: its EXIT trap fires
                       # after cmd_launch's frame is gone (launch is the one
                       # command that returns instead of exiting in-body)

# One command per invocation: the first command flag claims COMMAND (default:
# launch) and any second one is a hard error, raised at parse time before
# anything runs.
COMMAND="launch"
COMMAND_FLAG=""
set_command() {
  if [[ "$COMMAND" != "launch" ]]; then
    echo "Error: $1 conflicts with $COMMAND_FLAG" >&2; exit 1
  fi
  COMMAND="$2"
  COMMAND_FLAG="$1"
}

# Parse CLI args into the OPT_*/COMMAND globals. Must be called as
# `parse_args "$@"`: $# and shift inside a function operate on the function's
# own arguments, not the script's. `exit` in the branches below (-h, parse
# errors) ends the whole script, not just this function, so nothing after a
# parse error or -h can run.
parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      # session options
      -a|--args)
        [[ $# -lt 2 ]] && { echo "Error: $1 requires a string value" >&2; exit 1; }
        OPT_ARGS="$2"
        OPT_ARGS_GIVEN=true
        shift 2
        ;;
      -e|--effort)
        [[ $# -lt 2 ]] && { echo "Error: $1 requires a level" >&2; exit 1; }
        validate_effort "$2" || exit 1
        OPT_EFFORT="$2"
        OPT_EFFORT_GIVEN=true
        shift 2
        ;;
      -t|--terminal) OPT_TERMINAL=true; shift ;;
      -w|--workspace)
        [[ $# -lt 2 ]] && { echo "Error: $1 requires a path" >&2; exit 1; }
        OPT_WORKSPACE="$2"
        shift 2
        ;;

      # prompt options
      -y|--yes) OPT_YES=true; shift ;;
      -n|--no) OPT_NO=true; shift ;;

      # subcommands (then exit): noun-verb, mirroring config
      config)
        set_command "$1" config
        shift
        parse_config_args "$@"
        break
        ;;
      profile|image|podman|alias)
        parse_subcommand "$@"
        break
        ;;
      runtime)
        # Pin the container runtime, or `runtime --unset` to clear the override.
        # Mirrors `bind`: a top-level word taking a value or `--unset`, not a
        # `<noun> <verb>` subcommand. Session options precede it; the podman|docker
        # value is validated later in cmd_runtime_set, not here.
        shift
        case "${1:-}" in -h|--help) usage; exit 0 ;; esac
        if [[ $# -gt 0 && "$1" == "--unset" ]]; then
          set_command "runtime --unset" runtime-remove; shift
        elif [[ $# -gt 0 && "$1" != -* ]]; then
          set_command "runtime" runtime-set; OPT_RUNTIME_SET="$1"; shift
        elif [[ $# -gt 0 ]]; then
          echo "Error: unknown option '$1' for runtime (use: runtime <podman|docker> | runtime --unset)" >&2; exit 1
        else
          echo "Error: 'runtime' needs a value (podman or docker) or --unset" >&2; exit 1
        fi
        if [[ $# -gt 0 ]]; then
          echo "Error: unexpected argument '$1' after runtime (session options go before it)" >&2; exit 1
        fi
        break
        ;;
      bind|-p)
        # Map this workspace to a profile (old `map add`), or `bind --unset` to
        # remove the binding (old `map remove`). `-p` is a flag-spelled alias for
        # `bind`. The trailing bare word is the profile; session options must
        # precede `bind` like other commands. `bind` is the only session-side way
        # to name a profile (launch takes none).
        local bind_word="$1"
        shift
        local bind_cmd="map" bind_label="$bind_word"
        if [[ $# -gt 0 && "$1" == "--unset" ]]; then
          bind_cmd="unmap"; bind_label="$bind_word --unset"; shift
        fi
        set_command "$bind_label" "$bind_cmd"
        if [[ $# -gt 0 && "$1" != -* ]]; then
          OPT_PROFILE="${1,,}"
          validate_profile_name "$OPT_PROFILE" || exit 1
          shift
        fi
        if [[ $# -gt 0 ]]; then
          echo "Error: unexpected argument '$1' after $bind_word (session options go before it)" >&2; exit 1
        fi
        break
        ;;
      status) set_command "$1" status; shift ;;

      # command shortcuts: flag spellings of full commands
      -b) set_command "$1" build; shift ;;

      -h|--help) usage; exit 0 ;;

      # fallthrough: no leading bare word is a profile anymore (bind is the only
      # session-side profile selector), so an unknown token is an unknown command.
      -*)
        echo "Error: unknown option '$1'" >&2; usage >&2; exit 1
        ;;
      *)
        echo "Error: unknown command '$1' (to launch the bound profile run 'clause'; to select one, 'clause bind $1')" >&2
        usage >&2; exit 1
        ;;
    esac
  done

  # Command-vs-command conflicts are handled by set_command during parsing;
  # -y/-n are modifiers, so their conflict is checked after the full line is
  # parsed.
  if [[ "$OPT_YES" == true && "$OPT_NO" == true ]]; then
    echo "Error: -y and -n are mutually exclusive" >&2; exit 1
  fi
}

# ── Config subcommand parsing ───────────────────────────────────────────────

# Parse the tokens after `config` into the OPT_CONFIG_* globals. Grammar: leading
# flags (--local/--get/--reset/--list), then a positional <key> and optional
# <value>. Flags must precede the key so a dash-prefixed value (e.g. `config args
# '--effort high'`) is taken verbatim and never mistaken for a flag. Writes
# target the profile tier by default; -l/--local targets the workspace override
# tier (reads resolve across scopes, so --local combines only with set/--reset).
# Validates up front (like the old --*-set cases) so bad input fails before any
# side effect; `exit` here ends the whole script.
parse_config_args() {
  # Phase 1: leading flags; stop at the first non-flag token (the key).
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -l|--local)    OPT_CONFIG_SCOPE="workspace"; shift ;;
      --get)         OPT_CONFIG_ACTION="get"; shift ;;
      --reset)       OPT_CONFIG_ACTION="reset"; shift ;;
      --list)        OPT_CONFIG_ACTION="list"; shift ;;
      -h|--help)     usage; exit 0 ;;
      -*) echo "Error: unknown config option '$1'" >&2; exit 1 ;;
      *) break ;;
    esac
  done

  # Phase 2: positional <key> [value], taken verbatim (value may start with '-').
  if [[ $# -gt 0 ]]; then OPT_CONFIG_KEY="$1"; shift; fi
  if [[ $# -gt 0 ]]; then OPT_CONFIG_VALUE="$1"; OPT_CONFIG_VALUE_GIVEN=true; shift; fi
  if [[ $# -gt 0 ]]; then
    echo "Error: unexpected config argument '$1' (put flags before the key)" >&2; exit 1
  fi

  # Default action: a value means set, a bare key means get (git behavior).
  if [[ -z "$OPT_CONFIG_ACTION" ]]; then
    if [[ "$OPT_CONFIG_VALUE_GIVEN" == true ]]; then
      OPT_CONFIG_ACTION="set"
    elif [[ -n "$OPT_CONFIG_KEY" ]]; then
      OPT_CONFIG_ACTION="get"
    else
      echo "Error: config needs a key (args|effort|mount), or --list" >&2; exit 1
    fi
  fi

  # Validate key/scope/value up front (mirrors the old parse-time validation).
  if [[ "$OPT_CONFIG_ACTION" == list ]]; then
    if [[ -n "$OPT_CONFIG_KEY" ]]; then
      echo "Error: config --list takes no key" >&2; exit 1
    fi
  else
    if [[ -z "$OPT_CONFIG_KEY" ]]; then
      echo "Error: config --$OPT_CONFIG_ACTION needs a key (args|effort|mount)" >&2; exit 1
    fi
    validate_config_key "$OPT_CONFIG_KEY" || exit 1
  fi
  if [[ "$OPT_CONFIG_VALUE_GIVEN" == true && "$OPT_CONFIG_ACTION" != set ]]; then
    echo "Error: config --$OPT_CONFIG_ACTION takes no value" >&2; exit 1
  fi
  # Reads resolve across scopes; a scope flag on them would silently mean
  # nothing, so reject it instead.
  if [[ "$OPT_CONFIG_SCOPE" == workspace ]]; then
    case "$OPT_CONFIG_ACTION" in
      get|list)
        echo "Error: --local combines only with set and --reset (--get prints the effective value; --list shows both scopes)" >&2; exit 1 ;;
    esac
  fi
  # mount has no profile tier, so writing it needs an explicit --local; reads
  # stay scope-free (get resolves effectively, list shows it under workspace).
  if [[ "$OPT_CONFIG_KEY" == mount && "$OPT_CONFIG_SCOPE" == profile ]]; then
    case "$OPT_CONFIG_ACTION" in
      set)   echo "Error: 'mount' is workspace-only; use: clause config --local mount <path>" >&2; exit 1 ;;
      reset) echo "Error: 'mount' is workspace-only; use: clause config --local --reset mount" >&2; exit 1 ;;
    esac
  fi
  if [[ "$OPT_CONFIG_ACTION" == set ]]; then
    if [[ "$OPT_CONFIG_KEY" == effort ]]; then
      validate_effort "$OPT_CONFIG_VALUE" || exit 1
    elif [[ "$OPT_CONFIG_KEY" == mount ]]; then
      validate_mount_path "$OPT_CONFIG_VALUE" || exit 1
    fi
  fi
  return 0
}

# Valid keys for the config subcommand.
validate_config_key() {
  case "$1" in
    args|effort|mount) return 0 ;;
    *) echo "Error: unknown config key '$1'. Valid keys: args, effort, mount" >&2; return 1 ;;
  esac
}

# ── Subcommand parsing (profile / image / podman / alias) ────────────────────

# Print the valid verbs for a noun and exit 1. $1 = noun, $2 = the bad/empty verb.
subcommand_error() {
  local noun="$1" verb="$2" verbs=""
  case "$noun" in
    profile) verbs="create|delete|list" ;;
    image)   verbs="build|suggest" ;;
    podman)  verbs="enable|disable|reset" ;;
    alias)   verbs="create|delete" ;;
  esac
  if [[ -z "$verb" ]]; then
    echo "Error: '$noun' needs a subcommand ($verbs)" >&2
  else
    echo "Error: unknown subcommand '$noun $verb' (valid: $verbs)" >&2
  fi
  exit 1
}

# Parse a `<noun> <verb> [arg]` subcommand into COMMAND (+ OPT_PROFILE). Called as
# `parse_subcommand "$@"` with $1 = the noun. Each noun.verb maps to the same
# COMMAND value the old flags used, so the dispatch and cmd_* bodies are reused
# unchanged. Only `profile create`/`delete` take a trailing profile name (they name
# a profile, like `bind`); every other subcommand acts on the workspace's bound
# profile and rejects a trailing token. (`runtime` is not a subcommand noun: it is
# parsed inline in parse_args like `bind`.) `exit` here ends the whole script;
# trailing checks use if-blocks so the function ends on status 0 (set -e safety,
# like parse_config_args).
parse_subcommand() {
  local noun="$1"; shift
  local verb=""
  if [[ $# -gt 0 ]]; then verb="$1"; shift; fi
  case "$verb" in -h|--help) usage; exit 0 ;; esac

  case "$noun.$verb" in
    profile.create) set_command "profile create" create-profile ;;
    profile.delete) set_command "profile delete" delete-profile ;;
    profile.list)   set_command "profile list"   profile-list ;;
    image.build)    set_command "image build"    build ;;
    image.suggest)  set_command "image suggest"  suggest-updates ;;
    podman.enable)  set_command "podman enable"  podman-enable ;;
    podman.disable) set_command "podman disable" podman-disable ;;
    podman.reset)   set_command "podman reset"   podman-reset ;;
    alias.create)   set_command "alias create"   alias-create ;;
    alias.delete)   set_command "alias delete"   alias-delete ;;
    *) subcommand_error "$noun" "$verb" ;;
  esac

  # Trailing argument policy:
  #   profile create / delete  -> optional profile NAME (the only subcommands that
  #                               still name a profile; bind is the other namer)
  #   everything else          -> acts on the bound profile, so a trailing bare word
  #                               is an error pointing at `bind`
  # Session options must precede the subcommand, so a stray dash token is a
  # misplaced flag caught by the final unexpected-argument check.
  if [[ "$COMMAND" == create-profile || "$COMMAND" == delete-profile ]]; then
    if [[ $# -gt 0 && "$1" != -* ]]; then
      OPT_PROFILE="${1,,}"
      validate_profile_name "$OPT_PROFILE" || exit 1
      shift
    fi
  elif [[ $# -gt 0 && "$1" != -* ]]; then
    echo "Error: '$noun $verb' takes no profile argument; it acts on the bound profile (select one with: clause bind $1)" >&2; exit 1
  fi
  if [[ $# -gt 0 ]]; then
    echo "Error: unexpected argument '$1' (session options go before the subcommand)" >&2; exit 1
  fi
}

# ── Startup steps (main calls these in order before dispatching) ────────────

# Sets WORKSPACE: the validated absolute form of -w/--workspace, else $PWD.
resolve_workspace() {
  if [[ -n "$OPT_WORKSPACE" ]]; then
    if [[ ! -d "$OPT_WORKSPACE" ]]; then
      echo "Error: workspace '$OPT_WORKSPACE' is not a directory" >&2; exit 1
    fi
    WORKSPACE="$(realpath "$OPT_WORKSPACE")"
  else
    WORKSPACE="$(realpath "$PWD")"
  fi
}

# Create the ~/.clause layout idempotently. The guard keeps the documented
# promise that the pure read-only commands (status, profile list, and config
# get/list) never touch disk; -h never reaches this point (parse_args exits).
# seed_profile (a full seed of the default profile from default/) is defined
# further down the file: safe, because no function body runs until `main "$@"`
# on the last line, after every definition has been parsed.
bootstrap_state() {
  case "$COMMAND" in
    status|profile-list) return 0 ;;
    config)
      # get/list are pure reads (like the old -A/--args-view); set/reset mutate,
      # so they fall through to bootstrap like the old --*-set commands did.
      case "$OPT_CONFIG_ACTION" in
        get|list) return 0 ;;
      esac
      ;;
  esac
  seed_profile "$PROFILES_DIR/default"
}

# Soft runtime probe shared by detect_runtime and cmd_status: report what the
# runtime would be without validating, erroring, or exiting. Sets
# PROBED_RUNTIME (the override file's whitespace-stripped value, else the
# first of podman/docker on PATH, else empty) and PROBED_RUNTIME_SOURCE
# (file | detected | ""). The file value is reported as-is, even if invalid;
# detect_runtime layers the hard errors on top, cmd_status just displays it.
probe_runtime() {
  PROBED_RUNTIME=""
  PROBED_RUNTIME_SOURCE=""
  if [[ -f "$RUNTIME_FILE" ]]; then
    PROBED_RUNTIME="$(tr -d '[:space:]' < "$RUNTIME_FILE")"
    PROBED_RUNTIME_SOURCE="file"
  elif command -v podman &>/dev/null; then
    PROBED_RUNTIME="podman"
    PROBED_RUNTIME_SOURCE="detected"
  elif command -v docker &>/dev/null; then
    PROBED_RUNTIME="docker"
    PROBED_RUNTIME_SOURCE="detected"
  fi
  return 0
}

# Sets CONTAINER_CLI. Only commands that shell out to it get past the guard.
# Everything else (including runtime-set, which manages the very setting that
# drives detection) must not error on a runtime-less system.
detect_runtime() {
  case "$COMMAND" in
    build|delete-profile|podman-reset|launch) ;;
    *) return 0 ;;
  esac
  probe_runtime
  if [[ "$PROBED_RUNTIME_SOURCE" == "file" ]]; then
    if [[ -z "$PROBED_RUNTIME" ]]; then
      echo "Error: $RUNTIME_FILE is empty; remove it or run: clause runtime podman" >&2; exit 1
    fi
    if [[ "$PROBED_RUNTIME" != "podman" && "$PROBED_RUNTIME" != "docker" ]]; then
      echo "Error: invalid runtime '$PROBED_RUNTIME' in $RUNTIME_FILE. Must be 'podman' or 'docker'" >&2; exit 1
    fi
    if ! command -v "$PROBED_RUNTIME" &>/dev/null; then
      echo "Error: runtime '$PROBED_RUNTIME' set in $RUNTIME_FILE but not found on PATH" >&2; exit 1
    fi
  elif [[ -z "$PROBED_RUNTIME" ]]; then
    echo "Error: neither podman nor docker found on PATH" >&2; exit 1
  fi
  CONTAINER_CLI="$PROBED_RUNTIME"
}

# ── Workspace binding helpers ────────────────────────────────────────────────

# The workspace→profile binding lives in <workspace>/.clause/profile (a single
# line naming the bound profile), so it travels with the folder when moved and
# needs no central registry. All three act on the current $WORKSPACE.

# First line of the binding file, whitespace-stripped; empty if unbound. Guarded
# with [[ -f ]], so it never creates anything (read-only-safe). `return 0` keeps
# an empty/absent binding from tripping set -e at the call site.
read_binding() {
  local f="$WORKSPACE/.clause/profile" line=""
  [[ -f "$f" ]] || return 0
  read -r line < "$f" || true
  printf '%s\n' "${line//[[:space:]]/}"
  return 0
}

# Ensure the workspace .clause/ dir exists and carries a .gitignore of a single
# "*", so per-workspace clause state (binding, args, effort, mount) is never
# accidentally committed to the workspace's own repo. Idempotent: creates the
# .gitignore only when absent, never overwriting a user-edited one.
ensure_workspace_config_dir() {
  local dir="$WORKSPACE/.clause"
  mkdir -p "$dir"
  [[ -f "$dir/.gitignore" ]] || printf '*\n' > "$dir/.gitignore"
}

# Write <profile> as the binding, creating <workspace>/.clause first.
write_binding() {
  ensure_workspace_config_dir
  echo "$1" > "$WORKSPACE/.clause/profile"
}

# Remove the binding file (leaves an otherwise-empty .clause/ dir; harmless).
remove_binding() {
  rm -f "$WORKSPACE/.clause/profile"
}

# ── Container helpers ───────────────────────────────────────────────────────

image_exists() {
  "$CONTAINER_CLI" image inspect "$1" &>/dev/null
}

volume_exists() {
  "$CONTAINER_CLI" volume inspect "$1" &>/dev/null
}

# ── Prompt helpers ──────────────────────────────────────────────────────────

# Sets global PROMPT_REPLY to y, n, or q
prompt_ynq() {
  local message="$1"
  if [[ "$OPT_YES" == true ]]; then
    echo "${message} [y/n/q] y"
    PROMPT_REPLY="y"
    return
  fi
  if [[ "$OPT_NO" == true ]]; then
    echo "${message} [y/n/q] n"
    PROMPT_REPLY="n"
    return
  fi
  read -r -n 1 -p "${message} [y/n/q] " PROMPT_REPLY
  echo
}

# prompt_ynq wrapper: true only on an explicit yes
prompt_yes() {
  prompt_ynq "$1"
  [[ "$PROMPT_REPLY" =~ ^[yY]$ ]]
}

# Prompts for literal "yes"; returns 1 (false) if not confirmed.
# -n auto-declines; -y deliberately does not auto-confirm destructive actions.
confirm_yes() {
  local message="$1"
  local reply
  [[ "$OPT_NO" == true ]] && return 1
  read -r -p "${message} Type 'yes' to confirm: " reply
  [[ "$reply" == "yes" ]]
}

# ── Profile resolution helper (silent, for management commands) ─────────────

profile_for_management() {
  local bound
  bound="$(read_binding)"
  echo "${OPT_PROFILE:-${bound:-default}}"
}

# Profile names become directory names under ~/.clause/profiles/ (which
# profile delete rm -rfs) and the clause-<name> image / clause-<name>-containers
# volume tags, so accept only a safe lowercase token: no slashes (no path
# traversal) and no leading '.' or '-' (rejects '..' and flag-like names).
# Returns nonzero with a message on a bad name.
validate_profile_name() {
  if [[ "$1" =~ ^[a-z0-9][a-z0-9._-]*$ ]]; then
    return 0
  fi
  echo "Error: invalid profile name '$1'. Use lowercase letters, digits, '.', '_', '-'; the first character must be a letter or digit" >&2
  return 1
}

# Resolve PROFILE_NAME ($1 if given, else OPT_PROFILE > binding > default, via
# profile_for_management) and PROFILE_DIR; error if the name is invalid or the
# profile dir is absent. The name check is defense in depth behind the parse-time
# validation: it also covers names read from a hand-edited workspace binding
# file, so no traversal name can reach PROFILE_DIR (and profile delete's rm -rf).
# OPT_PROFILE is only ever set by bind / profile create / profile delete now.
require_profile() {
  PROFILE_NAME="${1:-$(profile_for_management)}"
  validate_profile_name "$PROFILE_NAME" || exit 1
  PROFILE_DIR="$PROFILES_DIR/$PROFILE_NAME"
  if [[ ! -d "$PROFILE_DIR" ]]; then
    echo "Error: profile '$PROFILE_NAME' does not exist. Create it with: clause profile create $PROFILE_NAME" >&2
    exit 1
  fi
}

# ── Layered config helpers ──────────────────────────────────────────────────

# Generic three-tier resolver shared by the args and effort knobs:
#   one-shot flag > workspace file > profile file.
# $1 mode:  raw   -> first line verbatim; a present file wins even if empty
#           token -> first line, whitespace-stripped; empty/whitespace skipped;
#                    validated via $7 (invalid value -> warn on stderr + skip)
# $2 oneshot_given  $3 oneshot_value  $4 oneshot_label
# $5 ws_file  $6 profile_file  $7 validator fn (token mode only)
# Sets LAYERED_VALUE and LAYERED_SOURCE ("" source = nothing found).
resolve_layered() {
  local mode="$1" oneshot_given="$2" oneshot_value="$3" oneshot_label="$4"
  local ws_file="$5" profile_file="$6" validator="${7:-}"
  LAYERED_VALUE=""
  LAYERED_SOURCE=""
  if [[ "$oneshot_given" == true ]]; then
    LAYERED_VALUE="$oneshot_value"
    LAYERED_SOURCE="$oneshot_label"
    return
  fi
  local src val
  for src in "$ws_file" "$profile_file"; do
    [[ -f "$src" ]] || continue
    read -r val < "$src" || true
    if [[ "$mode" == token ]]; then
      val="${val//[[:space:]]/}"
      [[ -z "$val" ]] && continue
      if [[ -n "$validator" ]] && ! "$validator" "$val" 2>/dev/null; then
        echo "Warning: ignoring invalid value '$val' in $src" >&2
        continue
      fi
    fi
    LAYERED_VALUE="$val"
    LAYERED_SOURCE="$src"
    return
  done
}

# Pick the profile-tier file to feed resolve_layered for a knob ($1 = args|effort),
# with a default-only fallback to the repo default/ template. A launch always
# re-seeds the `default` profile from default/ (bootstrap_state) *before* reading
# these files, so an ABSENT default-profile file resolves to the template value at
# launch. Read-only views (status, config get/list) must not seed, so they read the
# template directly here to report that real post-seed value. Only an absent file
# falls back: a present-but-empty file is a real value (seed never overwrites it),
# so it is returned as-is. Named profiles never re-seed at launch (an incomplete one
# hard-errors), so the fallback is default-only; and since launch's default-profile
# files always exist post-seed, the fallback never fires at launch (byte-identical).
profile_tier_file() {
  local name="$1" prof="$PROFILE_DIR/$1"
  if [[ "$PROFILE_NAME" == "default" && ! -f "$prof" && -f "$SCRIPT_DIR/default/$name" ]]; then
    printf '%s\n' "$SCRIPT_DIR/default/$name"
  else
    printf '%s\n' "$prof"
  fi
}

# Write <value> as the sole line of <path> and confirm. Shared by the *-set
# commands. Creating the target dir on first write is a no-op for the profile
# dir (already exists); the workspace .clause/ dir is created via
# ensure_workspace_config_dir so it also gets a .gitignore, distinguished by a
# plain path compare (config_file_for builds workspace paths under
# $WORKSPACE/.clause and profile paths under ~/.clause/profiles/<name>).
write_layered_file() {
  local dir; dir="$(dirname "$1")"
  if [[ "$dir" == "$WORKSPACE/.clause" ]]; then
    ensure_workspace_config_dir
  else
    mkdir -p "$dir"
  fi
  echo "$2" > "$1"
  echo "Wrote $1: $2"
}

# Remove <path> if present, else report its absence. Shared by the *-remove commands.
remove_layered_file() {
  if [[ -f "$1" ]]; then
    rm "$1"
    echo "Removed $1"
  else
    echo "No override at $1"
  fi
}

# ── Claude args resolution helper ───────────────────────────────────────────

# Resolve the args appended to claude: -a/--args one-shot > workspace
# .clause/args (present file wins, even empty) > profile args file (same) > repo
# default/ template (default profile only, when the profile file is absent; see
# profile_tier_file). Sets ARGS_LINE (first line of the winning source) and
# ARGS_SOURCE ("default template" for the template tier); an empty ARGS_SOURCE
# means no source was found. Uses globals WORKSPACE, PROFILE_NAME/DIR, SCRIPT_DIR.
resolve_args() {
  resolve_layered raw "$OPT_ARGS_GIVEN" "$OPT_ARGS" "-a/--args" \
    "$WORKSPACE/.clause/args" "$(profile_tier_file args)"
  ARGS_LINE="$LAYERED_VALUE"
  ARGS_SOURCE="$LAYERED_SOURCE"
  # A value pulled from the default/ template (profile_tier_file fallback) reads as
  # the built-in default, not a stored override, so give it a friendly source tag.
  # (An `if` block, not `[[ ]] && …`: as the function's last statement the latter
  # would return the false test's nonzero status and trip set -e in every caller.)
  if [[ "$ARGS_SOURCE" == "$SCRIPT_DIR/default/args" ]]; then
    ARGS_SOURCE="default template"
  fi
}

# ── Effort override resolution helpers ──────────────────────────────────────

# Valid levels for the claude --effort flag. Includes `max`, which settings.json's
# effortLevel does not accept: we drive the CLI flag (what the args file ships), not
# the setting. Returns nonzero with a message on an invalid level.
validate_effort() {
  case "$1" in
    low|medium|high|xhigh|max) return 0 ;;
    *) echo "Error: invalid effort '$1'. Must be one of: low, medium, high, xhigh, max" >&2; return 1 ;;
  esac
}

# Resolve the effort override, parallel to resolve_args: -e/--effort one-shot >
# workspace .clause/effort > profile effort file > repo default/ template (default
# profile only, absent profile file; see profile_tier_file). A one-shot -a bypasses
# the args files, so it also bypasses the stored effort files (only -e refines -a).
# Empty or whitespace files mean "unset" and fall through; a syntactically invalid
# file value is warned about and skipped, so a hand-edited file cannot break launch.
# Sets EFFORT_VALUE and EFFORT_SOURCE ("default template" for the template tier;
# empty EFFORT_SOURCE means no override). Uses globals WORKSPACE, PROFILE_NAME/DIR,
# SCRIPT_DIR.
resolve_effort() {
  EFFORT_VALUE=""
  EFFORT_SOURCE=""
  # -e wins; otherwise a one-shot -a is a complete args override that also
  # suppresses any stored effort (only -e refines -a).
  if [[ "$OPT_EFFORT_GIVEN" != true && "$OPT_ARGS_GIVEN" == true ]]; then
    return
  fi
  resolve_layered token "$OPT_EFFORT_GIVEN" "$OPT_EFFORT" "-e/--effort" \
    "$WORKSPACE/.clause/effort" "$(profile_tier_file effort)" validate_effort
  EFFORT_VALUE="$LAYERED_VALUE"
  EFFORT_SOURCE="$LAYERED_SOURCE"
  # As in resolve_args: a value from the default/ template reads as the built-in
  # default (what a launch would seed), so tag its source accordingly. Uses an `if`
  # block for the same set -e reason (a trailing false `[[ ]] && …` returns nonzero).
  if [[ "$EFFORT_SOURCE" == "$SCRIPT_DIR/default/effort" ]]; then
    EFFORT_SOURCE="default template"
  fi
}

# Inject EFFORT_VALUE into ARGS_LINE: replace an existing --effort / --effort=
# token, else append. Guarantees exactly one --effort in the final command; no-op
# when EFFORT_VALUE is empty. Rebuilds ARGS_LINE from tokens (downstream re-splits
# with read -ra, so collapsed spacing does not matter).
apply_effort_to_args() {
  [[ -z "$EFFORT_VALUE" ]] && return
  local -a toks out=()
  read -ra toks <<< "$ARGS_LINE" || true
  local i replaced=false
  for (( i=0; i<${#toks[@]}; i++ )); do
    case "${toks[i]}" in
      --effort)
        out+=(--effort "$EFFORT_VALUE")
        replaced=true
        i=$((i+1))  # skip old value; `((i++))` returns 1 at i=0 and trips set -e
        ;;
      --effort=*)
        out+=("--effort=$EFFORT_VALUE")
        replaced=true
        ;;
      *)
        out+=("${toks[i]}")
        ;;
    esac
  done
  [[ "$replaced" == false ]] && out+=(--effort "$EFFORT_VALUE")
  ARGS_LINE="${out[*]}"
}

# ── Mount path resolution helpers ───────────────────────────────────────────

# Encode a host-style absolute path into the /workspace subpath segment, matching
# the scheme Claude uses for ~/.claude/projects keys (`/` and `.` → `-`). Applies
# the two substitutions in the same order as the original inline encoding, so the
# default (no override) container path is byte-identical to before this knob.
encode_path() {
  local p="${1//\//-}"
  p="${p//./-}"
  printf '%s\n' "$p"
}

# The mount-path override must be an absolute path with no trailing slash (except
# root): it is encoded into the container's /workspace subpath and used as the
# cwd, and a trailing slash adds a stray `-` that no realpath ever produces,
# which would silently orphan Claude's per-project history. Returns nonzero with
# a message on a bad value.
validate_mount_path() {
  case "$1" in
    /) return 0 ;;
    /*/) echo "Error: invalid mount path '$1'. Remove the trailing slash; pass the canonical absolute path (e.g. \$(pwd -P))" >&2; return 1 ;;
    /*) return 0 ;;
    *) echo "Error: invalid mount path '$1'. Must be an absolute path (start with /)" >&2; return 1 ;;
  esac
}

# Resolve the logical path encoded into the container workspace path (bind-mount
# target + cwd). Precedence: <workspace>/.clause/mount (first line; read -r trims
# surrounding whitespace but keeps internal spaces; empty → ignored) > the real
# $WORKSPACE. The bind-mount *source* stays the real $WORKSPACE (see cmd_launch);
# only the container-side path is pinned, so moving the host folder need not
# change the container cwd (and thus Claude's project history key). The file
# value is revalidated here (invalid → warn + fall through), so a hand-edit
# cannot break launch. Always sets MOUNT_VALUE (defaults to $WORKSPACE) and
# MOUNT_SOURCE ("" = no override). Uses global WORKSPACE.
resolve_mount_path() {
  MOUNT_VALUE="$WORKSPACE"
  MOUNT_SOURCE=""
  # `return 0` (not bare `return`) is load-bearing under set -e: a bare return
  # here would propagate the failed `[[ -f ]]` test's status 1, and the bare
  # `resolve_mount_path` call in cmd_launch/cmd_status would then abort the script
  # on the common no-override path.
  local file="$WORKSPACE/.clause/mount" line
  [[ -f "$file" ]] || return 0
  read -r line < "$file" || true
  [[ -z "$line" ]] && return 0
  if validate_mount_path "$line" 2>/dev/null; then
    MOUNT_VALUE="$line"
    MOUNT_SOURCE="$file"
  else
    echo "Warning: ignoring invalid mount path '$line' in $file; using $WORKSPACE" >&2
  fi
}

# ── Default-template walk ───────────────────────────────────────────────────

# Every file in the repo default/ template, sorted: the single definition of a
# complete profile, shared by require_profile_files (the gate) and seed_profile
# (the copy). find walks dotpaths a `default/*` glob would skip (.claude/).
default_files() {
  find "$SCRIPT_DIR/default" -type f | sort
}

# ── Profile completeness helper ─────────────────────────────────────────────

# The defaults folder defines the required file set: every `default/<rel>` must
# exist in the profile. Errors (listing what is missing) if any is absent,
# instead of silently re-seeding. Launch-only gate; uses global PROFILE_NAME.
require_profile_files() {
  local profile_dir="$1" src rel
  local -a missing=()
  while IFS= read -r src; do
    rel="${src#"$SCRIPT_DIR/default/"}"
    [[ -f "$profile_dir/$rel" ]] || missing+=("$rel")
  done < <(default_files)
  [[ ${#missing[@]} -eq 0 ]] && return 0
  echo "Error: profile '$PROFILE_NAME' is missing required files: ${missing[*]}" >&2
  echo "Re-seed them with: clause image build   (rebuilds the image and fills missing files)" >&2
  exit 1
}

# ── Profile seeding helper ──────────────────────────────────────────────────

# default/ mirrors a profile's layout: default/<rel> seeds to <profile>/<rel>.
# Seeds only missing files (never overwrites); cp -p carries the +x bit on hooks.
# Walks default_files, the same list require_profile_files gates on.
# $1 = profile dir; $2 = "verbose" to echo each seeded path.
seed_profile() {
  local profile_dir="$1" verbose="${2:-}" src rel dest
  while IFS= read -r src; do
    rel="${src#"$SCRIPT_DIR/default/"}"
    dest="$profile_dir/$rel"
    [[ -f "$dest" ]] && continue
    mkdir -p "$(dirname "$dest")"
    cp -p "$src" "$dest"
    [[ "$verbose" == verbose ]] && echo "Seeded $dest"
  done < <(default_files)
  # return 0 is load-bearing under set -e: in non-verbose mode the loop's
  # trailing `[[ verbose ]] && echo` leaves status 1, which would otherwise
  # kill the script at any bare seed_profile call
  return 0
}

# ── Nested podman helpers ───────────────────────────────────────────────────

# The Containerfile block managed by --podman-enable / --podman-disable.
# Everything between the begin/end markers is owned by clause; --podman-disable
# deletes exactly that range. subuid/subgid 1:999 + 1001:64535 is the standard
# podman-in-podman layout for a uid-1000 user: it skips 1000 (already the
# user's own uid) and fits inside the ~65k uids the outer userns provides.
nested_containerfile_block() {
  cat <<'EOF'
# clause-nested-begin
USER root
RUN apt-get update && apt-get install -y \
    podman \
    uidmap \
    slirp4netns \
    fuse-overlayfs \
    podman-compose \
    && rm -rf /var/lib/apt/lists/* \
    && printf 'claude:1:999\nclaude:1001:64535\n' > /etc/subuid \
    && printf 'claude:1:999\nclaude:1001:64535\n' > /etc/subgid \
    && printf 'unqualified-search-registries = ["docker.io"]\n' > /etc/containers/registries.conf \
    && printf '[engine]\ncgroup_manager = "cgroupfs"\nevents_logger = "file"\n' >> /etc/containers/containers.conf
RUN arch="$(dpkg --print-architecture)" \
    && case "$arch" in amd64) larch=x86_64 ;; arm64) larch=arm64 ;; *) echo "unsupported arch: $arch" >&2; exit 1 ;; esac \
    && tag="$(curl -fsSLo /dev/null -w '%{url_effective}' https://github.com/jesseduffield/lazydocker/releases/latest)" \
    && tag="${tag##*/}" \
    && curl -fsSL "https://github.com/jesseduffield/lazydocker/releases/download/${tag}/lazydocker_${tag#v}_Linux_${larch}.tar.gz" \
       | tar -xz -C /usr/local/bin lazydocker
USER claude
RUN mkdir -p /home/claude/.local/share/containers
# lazydocker speaks the docker API; compose actions are mapped to podman-compose
RUN mkdir -p /home/claude/.config/lazydocker \
    && printf 'commandTemplates:\n  dockerCompose: podman-compose\n' > /home/claude/.config/lazydocker/config.yml
# lazydocker wrapper: start podman's API socket on demand, point DOCKER_HOST at it
# (alias ld shadows the binutils linker in interactive shells only)
RUN printf '%s\n' \
    '' \
    'lazydocker() {' \
    '  local sock' \
    '  sock="$(podman info --format "{{.Host.RemoteSocket.Path}}" 2>/dev/null)"' \
    '  sock="${sock#unix://}"' \
    '  if [ -z "$sock" ]; then' \
    '    echo "lazydocker: podman not available; nested podman must be enabled" >&2' \
    '    return 1' \
    '  fi' \
    '  if [ ! -S "$sock" ]; then' \
    '    (podman system service --time=0 >/dev/null 2>&1 &)' \
    '    local i=0' \
    '    while [ "$i" -lt 50 ] && [ ! -S "$sock" ]; do sleep 0.1; i=$((i+1)); done' \
    '  fi' \
    '  DOCKER_HOST="unix://$sock" command lazydocker "$@"' \
    '}' \
    "alias ld='lazydocker'" \
    >> /home/claude/.bashrc
# clause-nested-end
EOF
}

# ── Suggest-updates helpers ────────────────────────────────────────────────

# Print non-flag tokens that appear after the keyword in the given array.
# Usage: pkgs_after <keyword> <token...>
pkgs_after() {
  local keyword="$1"; shift
  local found=false tok
  for tok in "$@"; do
    if [[ "$found" == true && "$tok" != -* ]]; then
      echo "$tok"
    elif [[ "$tok" == "$keyword" ]]; then
      found=true
    fi
  done
}

# Render a RUN block for the given installer if its file has entries.
# Usage: render_block <file> <header> <footer>
render_block() {
  local file="$1" header="$2" footer="$3"
  [[ ! -s "$file" ]] && return 1
  local pkgs
  mapfile -t pkgs < <(sort -u "$file")
  echo "$header"
  local n=${#pkgs[@]} i
  for (( i=0; i<n-1; i++ )); do
    printf '    %s \\\n' "${pkgs[i]}"
  done
  printf '    %s' "${pkgs[n-1]}"
  if [[ -n "$footer" ]]; then
    printf ' \\\n%s\n' "$footer"
  else
    echo
  fi
  echo
  return 0
}

# ── Command: image build ─────────────────────────────────────────────────────

cmd_build() {
  require_profile
  seed_profile "$PROFILE_DIR"
  "$CONTAINER_CLI" build --no-cache -t "clause-$PROFILE_NAME" "$PROFILE_DIR"
  exit 0
}

# ── Command: profile create ────────────────────────────────────────────────

cmd_create_profile() {
  local existing
  PROFILE_NAME="$(profile_for_management)"
  PROFILE_DIR="$PROFILES_DIR/$PROFILE_NAME"
  if [[ -d "$PROFILE_DIR" ]]; then
    echo "Error: profile '$PROFILE_NAME' already exists" >&2; exit 1
  fi
  prompt_yes "Create profile '$PROFILE_NAME'?" || { echo "Aborted."; exit 0; }
  echo "Created profile '$PROFILE_NAME'"
  seed_profile "$PROFILE_DIR" verbose
  existing="$(read_binding)"
  if [[ -n "$existing" && "$existing" != "$PROFILE_NAME" ]]; then
    echo "Warning: $WORKSPACE is already bound to '$existing'" >&2
    if prompt_yes "Rebind to '$PROFILE_NAME'?"; then
      write_binding "$PROFILE_NAME"
      echo "Bound $WORKSPACE → $PROFILE_NAME"
    else
      echo "Kept existing binding: $WORKSPACE → $existing"
    fi
  else
    write_binding "$PROFILE_NAME"
    echo "Bound $WORKSPACE → $PROFILE_NAME"
  fi
  exit 0
}

# ── Command: profile delete ────────────────────────────────────────────────

cmd_delete_profile() {
  require_profile
  if [[ "$PROFILE_NAME" == "default" ]]; then
    echo "Error: cannot delete the default profile" >&2; exit 1
  fi
  confirm_yes "Delete profile '$PROFILE_NAME' and all its data?" || { echo "Aborted."; exit 0; }
  local image_name="clause-$PROFILE_NAME"
  local volume_name="clause-$PROFILE_NAME-containers"
  rm -rf "$PROFILE_DIR"
  if image_exists "$image_name"; then
    "$CONTAINER_CLI" rmi "$image_name" >/dev/null 2>&1 || true
    echo "Removed image '$image_name'"
  fi
  if volume_exists "$volume_name"; then
    "$CONTAINER_CLI" volume rm "$volume_name" >/dev/null 2>&1 || true
    echo "Removed volume '$volume_name'"
  fi
  echo "Deleted profile '$PROFILE_NAME'"
  echo "Note: any workspace still bound to '$PROFILE_NAME' (via its .clause/profile) will error on next launch; rebind it with: clause bind [profile]"
  exit 0
}

# ── Command: profile list ──────────────────────────────────────────────────

# All profiles. Bindings now live in each workspace's .clause/profile, so there is
# no central registry to enumerate here (see `status` for the current workspace's
# binding). Read-only: nullglob yields nothing when PROFILES_DIR is absent, so
# nothing is created here.
cmd_profile_list() {
  local found=false d
  echo "profiles:"
  shopt -s nullglob
  for d in "$PROFILES_DIR"/*/; do
    if [[ -f "$d/nested" ]]; then
      echo "  $(basename "$d") (nested)"
    else
      echo "  $(basename "$d")"
    fi
    found=true
  done
  shopt -u nullglob
  [[ "$found" == false ]] && echo "  (no profiles)"
  exit 0
}

# ── Command: config ────────────────────────────────────────────────────────

# git-style config surface over the three layered knobs (args/effort/mount).
# parse_config_args has populated the OPT_CONFIG_* globals; every read/write
# reuses the same helpers as launch, so precedence (workspace > profile) is
# identical to a real launch.

# Set CONFIG_FILE_PATH to the file backing <key> at the current scope. Profile
# scope resolves and requires the profile (like the old *-set-profile commands);
# workspace scope does not. mount is workspace-only (parse_config_args rejects
# mount without --local before we reach here).
config_file_for() {
  case "$1" in
    args|effort)
      if [[ "$OPT_CONFIG_SCOPE" == profile ]]; then
        require_profile; CONFIG_FILE_PATH="$PROFILE_DIR/$1"
      else
        CONFIG_FILE_PATH="$WORKSPACE/.clause/$1"
      fi ;;
    mount)
      CONFIG_FILE_PATH="$WORKSPACE/.clause/mount" ;;
  esac
}

# Resolve PROFILE_NAME/PROFILE_DIR silently for the read paths (get/list), like
# cmd_status: a missing profile must not error, it just yields no profile-tier
# value (resolve_* guard each file read with [[ -f ]]).
config_resolve_profile_silent() {
  PROFILE_NAME="$(profile_for_management)"
  PROFILE_DIR="$PROFILES_DIR/$PROFILE_NAME"
}

# Display string for a single config file at ONE scope, with no cross-tier
# resolution: absent -> "(unset)", present-but-empty first line -> "(empty)", else
# the first line verbatim. Used by config --list's per-scope breakdown.
config_scope_value() {
  local path="$1" val
  if [[ ! -f "$path" ]]; then
    printf '(unset)\n'
  else
    read -r val < "$path" || true
    if [[ -z "$val" ]]; then
      printf '(empty)\n'
    else
      printf '%s\n' "$val"
    fi
  fi
}

# One indented, aligned "  key: value" entry ($1 = key, $2 = file) under a heading.
config_list_entry() {
  printf '  %-7s %s\n' "$1:" "$(config_scope_value "$2")"
}

config_do_set() {
  config_file_for "$OPT_CONFIG_KEY"
  write_layered_file "$CONFIG_FILE_PATH" "$OPT_CONFIG_VALUE"
}

# Reset one key at the selected scope. Workspace scope deletes the override so
# the value falls through to the profile (the old --unset). Profile scope
# restores the repo template value instead of deleting: profile args/effort are
# in require_profile_files' required set, so a deleting reset would brick a
# named profile's launches until `image build` re-seeds. mount never reaches
# here at profile scope (parse_config_args rejects it without --local).
config_do_reset() {
  if [[ "$OPT_CONFIG_SCOPE" == profile ]]; then
    require_profile
    cp -p "$SCRIPT_DIR/default/$OPT_CONFIG_KEY" "$PROFILE_DIR/$OPT_CONFIG_KEY"
    local val=""
    read -r val < "$PROFILE_DIR/$OPT_CONFIG_KEY" || true
    echo "Reset $PROFILE_DIR/$OPT_CONFIG_KEY to template default: $val"
  else
    config_file_for "$OPT_CONFIG_KEY"
    remove_layered_file "$CONFIG_FILE_PATH"
  fi
}

# Print one key's raw effective value (scriptable; nothing when unset). Effort is
# NOT injected into args here: that is a launch concern (see cmd_status for the
# effort-injected `launch:` line). `return 0` keeps an empty value from tripping set -e.
config_do_get() {
  config_resolve_profile_silent
  local val=""
  case "$OPT_CONFIG_KEY" in
    args)   resolve_args;       val="$ARGS_LINE" ;;
    effort) resolve_effort;     val="$EFFORT_VALUE" ;;
    mount)  resolve_mount_path; [[ -n "$MOUNT_SOURCE" ]] && val="$MOUNT_VALUE" ;;
  esac
  [[ -n "$val" ]] && printf '%s\n' "$val"
  return 0
}

# Per-scope dump of what is stored where: the workspace tier and the profile tier,
# each read directly (no cross-tier resolution, no one-shot -a/-e, no default/
# template fallback). "Which tier wins, and its origin" is status's job (effective
# value + source), so --list needs no --show-origin: the scope headings already say
# where each value lives. mount is workspace-only, so it appears only under
# workspace. An uncreated profile dir just yields "(unset)" for every profile key.
config_do_list() {
  config_resolve_profile_silent
  echo "workspace ($WORKSPACE/.clause):"
  config_list_entry args   "$WORKSPACE/.clause/args"
  config_list_entry effort "$WORKSPACE/.clause/effort"
  config_list_entry mount  "$WORKSPACE/.clause/mount"
  if [[ -d "$PROFILE_DIR" ]]; then
    echo "profile $PROFILE_NAME ($PROFILE_DIR):"
  else
    echo "profile $PROFILE_NAME (not created):"
  fi
  config_list_entry args   "$PROFILE_DIR/args"
  config_list_entry effort "$PROFILE_DIR/effort"
}

cmd_config() {
  case "$OPT_CONFIG_ACTION" in
    set)   config_do_set ;;
    reset) config_do_reset ;;
    get)   config_do_get ;;
    list)  config_do_list ;;
  esac
  exit 0
}

# ── Command: status ────────────────────────────────────────────────────────

# Full effective config for this directory: profile, binding, mount, args,
# effort, runtime, image. Read-only (in the bootstrap_state allowlist) and
# tolerant of a missing profile or absent runtime, so it never errors and never
# creates ~/.clause. resolve_args/resolve_effort guard each file read with
# [[ -f ]], so an uncreated PROFILE_DIR just yields no profile-tier value.
cmd_status() {
  PROFILE_NAME="$(profile_for_management)"
  PROFILE_DIR="$PROFILES_DIR/$PROFILE_NAME"
  if [[ -d "$PROFILE_DIR" ]]; then
    echo "profile: $PROFILE_NAME"
  else
    echo "profile: $PROFILE_NAME (not created)"
  fi

  local binding
  binding="$(read_binding)"
  if [[ -n "$binding" ]]; then
    echo "binding: $WORKSPACE → $binding"
  else
    echo "binding: $WORKSPACE → (none, using default)"
  fi

  resolve_mount_path
  if [[ -n "$MOUNT_SOURCE" ]]; then
    echo "mount:   /workspace/$(encode_path "$MOUNT_VALUE") (source: $MOUNT_SOURCE)"
  else
    echo "mount:   /workspace/$(encode_path "$MOUNT_VALUE")"
  fi

  resolve_args
  resolve_effort
  local raw_args="$ARGS_LINE"
  apply_effort_to_args           # mutates ARGS_LINE -> the args a launch passes
  if [[ -n "$raw_args" ]]; then
    echo "args:    $raw_args${ARGS_SOURCE:+  (source: $ARGS_SOURCE)}"
  else
    echo "args:    (no args)${ARGS_SOURCE:+  (source: $ARGS_SOURCE)}"
  fi
  if [[ -n "$EFFORT_SOURCE" ]]; then
    echo "effort:  $EFFORT_VALUE  (source: $EFFORT_SOURCE)"
  else
    echo "effort:  (unset)"
  fi
  # The formatted args a normal (claude-mode) launch passes: raw args with the
  # effort level injected (apply_effort_to_args above). config --get args stays
  # the raw view; this launch: line is the combined one.
  if [[ -n "$ARGS_LINE" ]]; then
    echo "launch:  $ARGS_LINE"
  else
    echo "launch:  (no args)"
  fi

  # Soft probe via probe_runtime: report-only, never exits (unlike
  # detect_runtime, which layers hard errors on the same probe), so status
  # still works on a host with no container runtime installed.
  probe_runtime
  local rt="$PROBED_RUNTIME"
  if [[ -n "$rt" ]]; then
    echo "runtime: $rt"
  else
    echo "runtime: (none found)"
  fi

  local img="clause-$PROFILE_NAME"
  if [[ -n "$rt" ]] && command -v "$rt" &>/dev/null; then
    if "$rt" image inspect "$img" &>/dev/null; then
      echo "image:   $img (built)"
    else
      echo "image:   $img (not built)"
    fi
  else
    echo "image:   $img (runtime unavailable)"
  fi
  exit 0
}

# ── Command: image suggest ─────────────────────────────────────────────────

cmd_suggest_updates() {
  require_profile
  local log target target_note tmp any f line cmd
  local -a toks
  log="$PROFILE_DIR/.claude/clause-sudo.log"
  if [[ ! -f "$log" ]]; then
    echo "No sudo log found at $log"; exit 0
  fi

  if [[ -f "$PROFILE_DIR/Containerfile" ]]; then
    target="$PROFILE_DIR/Containerfile"
    target_note="profile Containerfile: $target"
  else
    target="$SCRIPT_DIR/default/Containerfile"
    target_note="default Containerfile (profile has no Containerfile; seed it with: clause image build)"
  fi

  tmp=$(mktemp -d)
  # EXIT traps replace rather than stack: safe because the dispatch runs one
  # command per invocation, so cmd_launch's cleanup trap can never follow this.
  # `tmp` being local is fine: this function exits in-body, so the trap fires
  # while its frame is still live.
  trap 'rm -rf "$tmp"' EXIT

  # Extract every COMMAND= payload from the sudo log
  # Sudo wraps long log lines at column 80 with 4-space-indented continuations;
  # join them back together before extracting the COMMAND= payload.
  sed ':a;N;$!ba;s/\n[[:space:]]\+/ /g' "$log" | awk -F' ; COMMAND=' 'NF>1 {print $2}' | while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    read -ra toks <<< "$line"
    cmd="${toks[0]##*/}"
    case "$cmd" in
      apt|apt-get)
        pkgs_after install "${toks[@]:1}" >> "$tmp/apt"
        ;;
      npm)
        # only -g / --global installs
        if printf '%s\n' "${toks[@]:1}" | grep -qxE -- '-g|--global'; then
          pkgs_after install "${toks[@]:1}" >> "$tmp/npm"
          pkgs_after i       "${toks[@]:1}" >> "$tmp/npm"
        fi
        ;;
      pip|pip3)
        # skip --user installs (those go to ~/.local, not the image)
        if ! printf '%s\n' "${toks[@]:1}" | grep -qx -- '--user'; then
          pkgs_after install "${toks[@]:1}" >> "$tmp/pip"
        fi
        ;;
      gem)   pkgs_after install "${toks[@]:1}" >> "$tmp/gem" ;;
      cargo) pkgs_after install "${toks[@]:1}" >> "$tmp/cargo" ;;
      snap)  pkgs_after install "${toks[@]:1}" >> "$tmp/snap" ;;
    esac
  done

  # Filter out packages already named in the target Containerfile: a candidate
  # is dropped only when its exact name appears as a token there (-x matches
  # the whole candidate line, so a `git` token no longer suppresses github-cli)
  for f in "$tmp"/*; do
    [[ -f "$f" ]] || continue
    grep -vxFf <(grep -oE '[a-zA-Z0-9_.+@/-]+' "$target" | sort -u) "$f" > "$f.new" || true
    mv "$f.new" "$f"
  done

  echo "# Containerfile suggestions for profile '$PROFILE_NAME'"
  echo "# Source log: $log"
  echo "# Target:     $target_note"
  echo

  any=false
  render_block "$tmp/apt" \
    "RUN apt-get update && apt-get install -y \\" \
    "    && rm -rf /var/lib/apt/lists/*" && any=true
  render_block "$tmp/npm"   "RUN npm install -g \\"    "" && any=true
  render_block "$tmp/pip"   "RUN pip install --no-cache-dir \\" "" && any=true
  render_block "$tmp/gem"   "RUN gem install \\"       "" && any=true
  render_block "$tmp/cargo" "RUN cargo install \\"     "" && any=true
  render_block "$tmp/snap"  "RUN snap install \\"      "" && any=true

  if [[ "$any" == false ]]; then
    echo "# No new installs detected (log empty or all packages already present in target)."
  else
    echo "# To apply: append the relevant blocks to $target, then: clause image build"
  fi
  exit 0
}

# ── Command: podman enable ─────────────────────────────────────────────────

cmd_podman_enable() {
  require_profile
  seed_profile "$PROFILE_DIR"
  if [[ -f "$PROFILE_DIR/nested" ]]; then
    echo "Nested podman already enabled for profile '$PROFILE_NAME'"
  else
    touch "$PROFILE_DIR/nested"
    echo "Enabled nested podman for profile '$PROFILE_NAME'"
  fi
  if grep -qF '# clause-nested-begin' "$PROFILE_DIR/Containerfile"; then
    echo "Containerfile already contains the nested podman block"
  else
    if prompt_yes "Append nested podman block to $PROFILE_DIR/Containerfile?"; then
      printf '\n' >> "$PROFILE_DIR/Containerfile"
      nested_containerfile_block >> "$PROFILE_DIR/Containerfile"
      echo "Appended nested podman block to $PROFILE_DIR/Containerfile"
    else
      echo "Skipped. Add this block to $PROFILE_DIR/Containerfile manually:"
      echo
      nested_containerfile_block
    fi
  fi
  echo "Rebuild the image to apply: clause image build"
  exit 0
}

# ── Command: podman disable ────────────────────────────────────────────────

cmd_podman_disable() {
  require_profile
  if [[ -f "$PROFILE_DIR/nested" ]]; then
    rm "$PROFILE_DIR/nested"
    echo "Disabled nested podman for profile '$PROFILE_NAME'"
  else
    echo "Nested podman is not enabled for profile '$PROFILE_NAME'"
  fi
  if [[ -f "$PROFILE_DIR/Containerfile" ]] && grep -qF '# clause-nested-begin' "$PROFILE_DIR/Containerfile"; then
    if prompt_yes "Remove nested podman block from $PROFILE_DIR/Containerfile?"; then
      sed -i '/^# clause-nested-begin$/,/^# clause-nested-end$/d' "$PROFILE_DIR/Containerfile"
      # trim the separator blank line(s) --podman-enable added before the block
      while [[ "$(wc -c < "$PROFILE_DIR/Containerfile")" -gt 1 && -z "$(tail -c 2 "$PROFILE_DIR/Containerfile")" ]]; do
        truncate -s -1 "$PROFILE_DIR/Containerfile"
      done
      echo "Removed nested podman block (rebuild to slim the image: clause image build)"
    else
      echo "Kept nested podman block (its packages are inert without the launch flags)"
    fi
  fi
  echo "Note: the storage volume 'clause-$PROFILE_NAME-containers' is kept, if present."
  echo "Remove it with: clause podman reset"
  exit 0
}

# ── Command: podman reset ──────────────────────────────────────────────────

cmd_podman_reset() {
  PROFILE_NAME="$(profile_for_management)"
  local volume_name="clause-$PROFILE_NAME-containers"
  if ! volume_exists "$volume_name"; then
    echo "No nested podman storage volume found for profile '$PROFILE_NAME'"
    exit 0
  fi
  confirm_yes "Remove volume '$volume_name'? This deletes all inner images, containers, and volumes (including any data in them)." || { echo "Aborted."; exit 0; }
  "$CONTAINER_CLI" volume rm "$volume_name" >/dev/null
  echo "Removed volume '$volume_name'. It will be recreated empty on the next nested launch."
  exit 0
}

# ── Command: alias create ──────────────────────────────────────────────────

cmd_alias_create() {
  local alias_line="alias clause='$SCRIPT_DIR/clause' # clause-alias"
  local alias_added=false rc
  for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    if [[ ! -f "$rc" ]]; then
      echo "Skipping $rc (not found)"
      continue
    fi
    if grep -qF '# clause-alias' "$rc"; then
      echo "Alias already exists in $rc"
      continue
    fi
    prompt_yes "Add clause alias to $rc?" || continue
    echo "" >> "$rc"
    echo "$alias_line" >> "$rc"
    echo "Added alias to $rc"
    alias_added=true
  done
  [[ "$alias_added" == false ]] && echo "No alias added."
  exit 0
}

# ── Command: alias delete ──────────────────────────────────────────────────

cmd_alias_delete() {
  local rc
  for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    [[ ! -f "$rc" ]] && continue
    if ! grep -qF '# clause-alias' "$rc"; then
      echo "No alias found in $rc"
      continue
    fi
    confirm_yes "Remove clause alias from $rc?" || { echo "Aborted."; continue; }
    sed -i '/# clause-alias$/d' "$rc"
    echo "Removed alias from $rc"
  done
  exit 0
}

# ── Command: runtime <podman|docker> ──────────────────────────────────────

cmd_runtime_set() {
  if [[ "$OPT_RUNTIME_SET" != "podman" && "$OPT_RUNTIME_SET" != "docker" ]]; then
    echo "Error: invalid runtime '$OPT_RUNTIME_SET'. Must be 'podman' or 'docker'" >&2; exit 1
  fi
  if ! command -v "$OPT_RUNTIME_SET" &>/dev/null; then
    echo "Error: '$OPT_RUNTIME_SET' not found on PATH" >&2; exit 1
  fi
  if [[ -f "$RUNTIME_FILE" ]]; then
    local existing
    existing="$(tr -d '[:space:]' < "$RUNTIME_FILE")"
    prompt_yes "Runtime already set to '$existing'. Override with '$OPT_RUNTIME_SET'?" || { echo "Aborted."; exit 0; }
  fi
  echo "$OPT_RUNTIME_SET" > "$RUNTIME_FILE"
  echo "Runtime set to '$OPT_RUNTIME_SET' ($RUNTIME_FILE)"
  exit 0
}

# ── Command: runtime --unset ───────────────────────────────────────────────

cmd_runtime_remove() {
  if [[ ! -f "$RUNTIME_FILE" ]]; then
    echo "Error: no runtime override is set" >&2; exit 1
  fi
  confirm_yes "Remove runtime override?" || { echo "Aborted."; exit 0; }
  rm "$RUNTIME_FILE"
  echo "Runtime override removed. Auto-detection will be used."
  exit 0
}

# ── Command: bind ──────────────────────────────────────────────────────────

cmd_map() {
  require_profile "${OPT_PROFILE:-default}"
  local existing
  existing="$(read_binding)"
  if [[ -n "$existing" ]]; then
    echo "Warning: $WORKSPACE is already bound to '$existing'" >&2
    prompt_yes "Rebind to '$PROFILE_NAME'?" || { echo "Aborted."; exit 0; }
  fi
  write_binding "$PROFILE_NAME"
  echo "Bound $WORKSPACE → $PROFILE_NAME"
  exit 0
}

# ── Command: bind --unset ──────────────────────────────────────────────────

cmd_unmap() {
  local saved
  saved="$(read_binding)"
  if [[ -z "$saved" ]]; then
    echo "Error: no binding found for $WORKSPACE" >&2; exit 1
  fi
  if prompt_yes "Remove binding $WORKSPACE → $saved?"; then
    remove_binding
    echo "Removed binding: $WORKSPACE → $saved"
  else
    echo "Aborted."
  fi
  exit 0
}

# ── Command: launch (default) ──────────────────────────────────────────────

cmd_launch() {
  # ── Resolve profile ───────────────────────────────────────────────────────
  # Launch never takes a profile argument: the profile is whatever this workspace
  # is bound to (via `clause bind`, recorded in <workspace>/.clause/profile), else
  # `default`. On first use from an unbound workspace, offer to record the default
  # binding (the y/n/q first-run prompt).
  local saved
  saved="$(read_binding)"
  if [[ -n "$saved" ]]; then
    PROFILE_NAME="$saved"
  else
    PROMPT_REPLY=""
    prompt_ynq "No binding found. Save $WORKSPACE → default?"
    case "$PROMPT_REPLY" in
      y|Y) write_binding "default"; PROFILE_NAME="default" ;;
      n|N) PROFILE_NAME="default" ;;
      *)   echo "Aborted."; exit 0 ;;
    esac
  fi

  require_profile "$PROFILE_NAME"

  # ── Require a complete profile (strict: no silent re-seed at launch) ───────
  require_profile_files "$PROFILE_DIR"

  # ── Ensure image exists ───────────────────────────────────────────────────
  local image_name="clause-$PROFILE_NAME"
  local volume_name="clause-$PROFILE_NAME-containers"
  if ! image_exists "$image_name"; then
    echo "Error: '$image_name' image not found. Build it with: clause image build" >&2
    exit 1
  fi

  # ── Resolve container command ─────────────────────────────────────────────
  # Args are resolved in both modes (the same sequence status renders as its
  # launch: line) because the result is also exported to the container as
  # CLAUSE_ARGS, which the baked in-container clause alias expands. Under -t
  # they shape only that alias; bash itself still gets no args.
  local -a container_cmd args_array
  resolve_args
  resolve_effort
  apply_effort_to_args
  if [[ "$OPT_TERMINAL" == true ]]; then
    container_cmd=(bash)
  else
    container_cmd=(claude)
    if [[ -n "$ARGS_LINE" ]]; then
      read -ra args_array <<< "$ARGS_LINE"
      container_cmd+=("${args_array[@]}")
    fi
  fi

  # ── Launch container ──────────────────────────────────────────────────────
  # CONTAINER_NAME must stay global (not local): launch is the one command that
  # returns instead of exiting in-body, so the EXIT trap fires after this
  # frame is gone and cleanup would see a local as unset (set -u would error).
  CONTAINER_NAME="clause-$$"

  cleanup() {
    "$CONTAINER_CLI" stop "$CONTAINER_NAME" 2>/dev/null || true
  }
  trap cleanup EXIT INT TERM

  local -a user_flags=()
  if [[ "$CONTAINER_CLI" == "podman" ]]; then
    user_flags+=(--userns=keep-id:uid=1000,gid=1000)
  else
    user_flags+=(--user "$(id -u):$(id -g)")
  fi

  # Nested podman: the devices and relaxations rootless podman needs inside the
  # session, plus a named volume so inner images survive the ephemeral container.
  # A volume (not a profile bind mount) keeps nested-subuid-owned files out of
  # the profile dir (plain rm -rf could not delete them) and, living outside the
  # container's overlay rootfs, lets inner storage use native overlayfs.
  local -a nested_flags=()
  if [[ -f "$PROFILE_DIR/nested" ]]; then
    nested_flags+=(-v "$volume_name:/home/claude/.local/share/containers")
    if [[ -e /dev/fuse ]]; then
      nested_flags+=(--device /dev/fuse)
    else
      echo "Warning: /dev/fuse not found on host; nested podman storage may fall back to vfs" >&2
    fi
    if [[ -e /dev/net/tun ]]; then
      nested_flags+=(--device /dev/net/tun)
    else
      echo "Warning: /dev/net/tun not found on host; nested container networking will be limited" >&2
    fi
    nested_flags+=(--security-opt label=disable)
    if [[ "$CONTAINER_CLI" == "docker" ]]; then
      # docker's default seccomp/apparmor profiles block syscalls nested podman
      # needs (unshare, mount); podman's defaults allow them
      nested_flags+=(--security-opt seccomp=unconfined --security-opt apparmor=unconfined)
    fi
    if [[ ! -f "$PROFILE_DIR/Containerfile" ]] || ! grep -qi podman "$PROFILE_DIR/Containerfile"; then
      echo "Warning: nested podman is enabled but $PROFILE_DIR/Containerfile does not appear to install podman." >&2
      echo "Fix with: clause podman enable (then rebuild: clause image build)" >&2
    fi
  fi

  # Encode the workspace path into the container-side /workspace subpath + cwd
  # (`/` and `.` → `-`, Claude's ~/.claude/projects key scheme) so each host
  # workspace gets a distinct cwd and keeps its per-project state separate.
  # resolve_mount_path lets a workspace pin the *logical* path that gets encoded
  # (via <workspace>/.clause/mount), so moving the host folder need not change the
  # container cwd (and thus Claude's history). The bind-mount source below stays
  # the real $WORKSPACE; only the target/cwd are pinned.
  resolve_mount_path
  local container_workspace
  container_workspace="/workspace/$(encode_path "$MOUNT_VALUE")"

  "$CONTAINER_CLI" run --rm -it --name "$CONTAINER_NAME" \
    "${user_flags[@]}" \
    "${nested_flags[@]}" \
    -v "$PROFILE_DIR/.claude:/home/claude/.claude" \
    -v "$PROFILE_DIR/.claude.json:/home/claude/.claude.json" \
    -v "$PROFILE_DIR/.gitconfig:/home/claude/.gitconfig" \
    -v "$WORKSPACE:$container_workspace" \
    -e "TERM=xterm-256color" \
    -e "CLAUSE_ARGS=$ARGS_LINE" \
    -w "$container_workspace" \
    "$image_name" \
    "${container_cmd[@]}"
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
  parse_args "$@"
  resolve_workspace
  bootstrap_state
  detect_runtime

  case "$COMMAND" in
    build)               cmd_build ;;
    create-profile)      cmd_create_profile ;;
    delete-profile)      cmd_delete_profile ;;
    profile-list)        cmd_profile_list ;;
    status)              cmd_status ;;
    config)              cmd_config ;;
    suggest-updates)     cmd_suggest_updates ;;
    podman-enable)       cmd_podman_enable ;;
    podman-disable)      cmd_podman_disable ;;
    podman-reset)        cmd_podman_reset ;;
    alias-create)        cmd_alias_create ;;
    alias-delete)        cmd_alias_delete ;;
    runtime-set)         cmd_runtime_set ;;
    runtime-remove)      cmd_runtime_remove ;;
    map)                 cmd_map ;;
    unmap)               cmd_unmap ;;
    launch)              cmd_launch ;;
    *) echo "Error: unhandled command '$COMMAND' (internal bug)" >&2; exit 1 ;;
  esac
}

# Keep this a bare call on the last line. Wrapping it in a conditional (`if`,
# `||`, `&&`) would disable `set -e` inside main and everything it calls.
# Being the only top-level statement also means bash has parsed the entire
# file before any logic runs, so editing this script while a session is live
# cannot make the running instance execute a half-written file.
main "$@"
