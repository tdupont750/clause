{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "/etc/apt",
      "/tmp",
      "/usr/bin",
      "/usr/local/bin",
      "/var/log"
    ],
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(cd * && git *)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(cut:*)",
      "Bash(diff:*)",
      "Bash(dotnet:*)",
      "Bash(dotnet-counters:*)",
      "Bash(dotnet-dump:*)",
      "Bash(dotnet-ef:*)",
      "Bash(dotnet-format:*)",
      "Bash(dotnet-ildasm:*)",
      "Bash(dotnet-outdated:*)",
      "Bash(dotnet-script:*)",
      "Bash(dotnet-trace:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(tee:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xargs:*)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push * --force)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "~/.claude/hooks/set-bg.sh reset" }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "~/.claude/hooks/set-bg.sh '#2b0e47'" }] }
    ],
    "PostToolUse": [
      { "hooks": [{ "type": "command", "command": "~/.claude/hooks/set-bg.sh '#2b0e47'" }] }
    ],
    "Notification": [
      { "hooks": [{ "type": "command", "command": "~/.claude/hooks/set-bg.sh reset" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "~/.claude/hooks/set-bg.sh reset" }] }
    ],
    "StopFailure": [
      { "hooks": [{ "type": "command", "command": "~/.claude/hooks/set-bg.sh reset" }] }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "command", "command": "~/.claude/hooks/set-bg.sh reset" }] }
    ]
  }
}
